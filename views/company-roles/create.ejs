<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Create Role - CRM',
    activeNav: 'company-roles'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Create Role</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item">User Management</li>
                                        <li class="breadcrumb-item"><a href="/company/roles">Roles</a></li>
                                        <li class="breadcrumb-item active">Create</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row justify-content-center">
                        <div class="col-lg-10">
                            <div class="card">
                                <div class="card-header">
                                    <h4 class="card-title mb-0">New Role</h4>
                                </div>
                                <div class="card-body">
                                    <% if (error) { %>
                                        <div class="alert alert-danger" role="alert"><%= error %></div>
                                    <% } %>

                                    <form action="/company/roles" method="post">
                                        <div class="mb-3">
                                            <label for="name" class="form-label">Role name</label>
                                            <input type="text" class="form-control" id="name" name="name" value="<%= values.name || '' %>" required>
                                        </div>

                                        <div class="mb-4">
                                            <label for="description" class="form-label">Description</label>
                                            <input type="text" class="form-control" id="description" name="description" value="<%= values.description || '' %>">
                                        </div>

                                    <h5 class="mb-3">Feature Permissions</h5>
                                    <p class="text-muted">Choose one access level per feature. Edit includes view access.</p>
                                        <%- include('_permission-matrix', { role: null }) %>

                                        <div class="d-flex gap-2 mt-4">
                                            <button class="btn btn-success" type="submit">Create Role</button>
                                            <a href="/company/roles" class="btn btn-light">Cancel</a>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
