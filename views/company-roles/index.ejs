<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Roles - CRM',
    activeNav: 'company-roles'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Roles</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item">User Management</li>
                                        <li class="breadcrumb-item active">Roles</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Company Roles</h4>
                                    <% if (user.can('role_management', 'edit')) { %>
                                        <div class="flex-shrink-0">
                                            <a href="/company/roles/new" class="btn btn-success btn-sm">
                                                <i class="ri-add-line align-middle me-1"></i> Create Role
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="card-body">
                                    <% if (roles.length === 0) { %>
                                        <p class="text-muted mb-0">No roles configured.</p>
                                    <% } else { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Name</th>
                                                        <th>Type</th>
                                                        <th>Team Members</th>
                                                        <th>Status</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% roles.forEach(function(role) { %>
                                                        <tr>
                                                            <td class="fw-medium"><%= role.name %></td>
                                                            <td>
                                                                <% if (role.isSystem) { %>
                                                                    <span class="badge bg-secondary-subtle text-secondary">System</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-info-subtle text-info">Custom</span>
                                                                <% } %>
                                                            </td>
                                                            <td><%= roleUserCounts[role.id] || 0 %></td>
                                                            <td>
                                                                <% if (role.isActive) { %>
                                                                    <span class="badge bg-success-subtle text-success">Active</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <% if (role.isSystem && role.slug === 'administrator') { %>
                                                                    <span class="text-muted small">Built-in</span>
                                                                <% } else if (user.can('role_management', 'edit')) { %>
                                                                    <a href="/company/roles/<%= role.id %>/edit" class="btn btn-soft-primary btn-sm">Edit</a>
                                                                <% } else { %>
                                                                    <span class="text-muted small">View only</span>
                                                                <% } %>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
