<%
    const selectedPermissions = values.permissions !== undefined ? values.permissions : (role ? role.permissions : {});
    const selectedCapabilities = values.capabilities !== undefined ? values.capabilities : (role ? role.capabilities : []);
    const capabilityList = Array.isArray(selectedCapabilities) ? selectedCapabilities : [];
%>

<div class="table-responsive">
    <table class="table table-bordered align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Feature</th>
                <th class="text-center" style="width: 280px;">Access</th>
            </tr>
        </thead>
        <tbody>
            <% if (availableFeatures.length === 0) { %>
                <tr>
                    <td colspan="2" class="text-muted">
                        No plan features are enabled for your company. Ask your platform administrator to assign a plan that includes features.
                    </td>
                </tr>
            <% } else { %>
                <% availableFeatures.forEach(function(feature) { %>
                    <% const accessLevel = getFeatureAccessLevel(selectedPermissions, feature.key); %>
                    <tr>
                        <td>
                            <div class="fw-medium"><%= feature.label %></div>
                            <% if (feature.description) { %>
                                <div class="text-muted small"><%= feature.description %></div>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-3 flex-wrap">
                                <div class="form-check form-check-inline mb-0">
                                    <input
                                        class="form-check-input"
                                        type="radio"
                                        name="permissions[<%= feature.key %>]"
                                        id="perm-<%= feature.key %>-none"
                                        value="none"
                                        <%= accessLevel === 'none' ? 'checked' : '' %>
                                    >
                                    <label class="form-check-label" for="perm-<%= feature.key %>-none">None</label>
                                </div>
                                <div class="form-check form-check-inline mb-0">
                                    <input
                                        class="form-check-input"
                                        type="radio"
                                        name="permissions[<%= feature.key %>]"
                                        id="perm-<%= feature.key %>-view"
                                        value="view"
                                        <%= accessLevel === 'view' ? 'checked' : '' %>
                                    >
                                    <label class="form-check-label" for="perm-<%= feature.key %>-view">View</label>
                                </div>
                                <div class="form-check form-check-inline mb-0">
                                    <input
                                        class="form-check-input"
                                        type="radio"
                                        name="permissions[<%= feature.key %>]"
                                        id="perm-<%= feature.key %>-edit"
                                        value="edit"
                                        <%= accessLevel === 'edit' ? 'checked' : '' %>
                                    >
                                    <label class="form-check-label" for="perm-<%= feature.key %>-edit">Edit</label>
                                </div>
                            </div>
                            <% if (accessLevel === 'edit') { %>
                                <div class="text-muted small mt-1">Edit includes view access.</div>
                            <% } %>
                        </td>
                    </tr>
                <% }); %>
            <% } %>
        </tbody>
    </table>
</div>

<% if (typeof availableCapabilities !== 'undefined' && availableCapabilities.length) { %>
    <hr class="my-4">
    <h5 class="mb-3">Administrative Capabilities</h5>
    <p class="text-muted">Capabilities control access to company administration pages. They are separate from plan features.</p>
    <div class="row">
        <% availableCapabilities.forEach(function(capability) { %>
            <div class="col-md-6">
                <div class="form-check mb-2">
                    <input
                        class="form-check-input"
                        type="checkbox"
                        name="capabilities"
                        value="<%= capability.key %>"
                        id="capability-<%= capability.key %>"
                        <%= capabilityList.includes(capability.key) ? 'checked' : '' %>
                    >
                    <label class="form-check-label" for="capability-<%= capability.key %>">
                        <span class="fw-medium"><%= capability.label %></span>
                        <% if (capability.description) { %>
                            <span class="d-block text-muted small"><%= capability.description %></span>
                        <% } %>
                    </label>
                </div>
            </div>
        <% }); %>
    </div>
<% } %>
