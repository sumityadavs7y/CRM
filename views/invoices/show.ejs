<%- include('../partials/velzon/app-layout-open', {
    pageTitle: invoice.invoiceNumber + ' - Invoice',
    activeNav: 'accounts-invoices'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0"><%= invoice.invoiceNumber %></h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item"><a href="/company/accounts/invoices">Invoices</a></li>
                                        <li class="breadcrumb-item active"><%= invoice.invoiceNumber %></li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
                    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

                    <div class="row mb-3">
                        <div class="col-12 d-flex flex-wrap gap-2">
                            <a href="/company/accounts/invoices" class="btn btn-light btn-sm">Back to list</a>
                            <% if (invoice.quotation) { %>
                                <a href="/company/accounts/quotations/<%= invoice.quotation.id %>" class="btn btn-soft-primary btn-sm">View quotation</a>
                            <% } %>
                            <% if (canViewProjects && invoice.projectId && hasLinkedInventory) { %>
                                <a href="<%= buildProjectInventoryUrl(invoice.projectId) %>" class="btn btn-soft-info btn-sm">
                                    <i class="ri-building-4-line"></i> View inventory
                                </a>
                            <% } %>
                            <% if (canDeleteInvoice) { %>
                                <form action="/company/accounts/invoices/<%= invoice.id %>/delete" method="post" class="d-inline" onsubmit='return confirm(<%- JSON.stringify(deleteConfirmMessage) %>);'>
                                    <button type="submit" class="btn btn-soft-danger btn-sm">Delete invoice</button>
                                </form>
                            <% } %>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-8">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between">
                                    <h5 class="card-title mb-0">Invoice details</h5>
                                    <span class="badge <%= getInvoiceStatusBadgeClass(invoice.status) %>"><%= formatInvoiceStatus(invoice.status) %></span>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6"><strong>Customer:</strong> <%= invoice.customerName %></div>
                                        <div class="col-md-6"><strong>Email:</strong> <%= invoice.customerEmail %></div>
                                        <div class="col-md-6"><strong>Issue date:</strong> <%= invoice.issueDate %></div>
                                        <div class="col-md-6"><strong>Due date:</strong> <%= invoice.dueDate || '—' %></div>
                                        <% if (invoice.project) { %>
                                            <div class="col-md-6"><strong>Project:</strong>
                                                <% if (canViewProjects && hasLinkedInventory) { %>
                                                    <a href="<%= buildProjectInventoryUrl(invoice.project.id) %>"><%= invoice.project.name %></a>
                                                <% } else if (canViewProjects) { %>
                                                    <a href="/company/projects/<%= invoice.project.id %>"><%= invoice.project.name %></a>
                                                <% } else { %>
                                                    <%= invoice.project.name %>
                                                <% } %>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-bordered mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Description</th>
                                                    <th class="text-end">Qty</th>
                                                    <th class="text-end">Rate</th>
                                                    <th class="text-end">Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% (invoice.lineItems || []).forEach(function(line, index) { %>
                                                    <tr>
                                                        <td><%= index + 1 %></td>
                                                        <td>
                                                            <%= line.description %>
                                                            <% if (line.unitSnapshot && line.unitSnapshot.blockName) { %>
                                                                <div class="text-muted fs-12"><%= line.unitSnapshot.blockName %> · <%= line.unitSnapshot.unitNumber || '' %></div>
                                                            <% } %>
                                                            <% var linkedUnitId = getLineProjectUnitId(line); %>
                                                            <% if (canViewProjects && invoice.projectId && linkedUnitId) { %>
                                                                <div class="mt-1">
                                                                    <a href="<%= buildProjectInventoryUrl(invoice.projectId, linkedUnitId) %>" class="fs-12">View in inventory</a>
                                                                </div>
                                                            <% } %>
                                                        </td>
                                                        <td class="text-end"><%= line.quantity %></td>
                                                        <td class="text-end"><%= formatIndianCurrency(line.unitPrice) %></td>
                                                        <td class="text-end"><%= formatIndianCurrency(line.lineTotal) %></td>
                                                    </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h5 class="card-title mb-0">Payments received</h5>
                                    <% if (canRecordPayments) { %>
                                        <button type="button" class="btn btn-success btn-sm" data-bs-toggle="collapse" data-bs-target="#record-payment-form">
                                            Record payment
                                        </button>
                                    <% } %>
                                </div>
                                <div class="card-body">
                                    <% if (canRecordPayments) { %>
                                        <div class="collapse mb-4" id="record-payment-form">
                                            <div class="border rounded p-3 bg-light-subtle">
                                                <h6 class="mb-3">Record payment</h6>
                                                <form action="/company/accounts/invoices/<%= invoice.id %>/receipts" method="post">
                                                    <div class="row g-3">
                                                        <div class="col-md-4">
                                                            <label class="form-label">Amount <span class="text-danger">*</span></label>
                                                            <input type="number" name="amount" class="form-control" step="0.01" min="0.01" max="<%= invoice.amountDue %>" required placeholder="0.00">
                                                            <div class="form-text">Maximum: <%= formatIndianCurrency(invoice.amountDue) %></div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label">Payment date <span class="text-danger">*</span></label>
                                                            <input type="date" name="paymentDate" class="form-control" value="<%= new Date().toISOString().slice(0, 10) %>" required>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label">Method</label>
                                                            <select name="paymentMethod" class="form-select">
                                                                <% paymentMethods.forEach(function(method) { %>
                                                                    <option value="<%= method.key %>"<%= method.key === 'bank_transfer' ? ' selected' : '' %>><%= method.label %></option>
                                                                <% }); %>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label">Reference</label>
                                                            <input type="text" name="reference" class="form-control" placeholder="Cheque / UTR number">
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label">Notes</label>
                                                            <input type="text" name="notes" class="form-control" placeholder="Optional notes">
                                                        </div>
                                                        <div class="col-12">
                                                            <button type="submit" class="btn btn-success btn-sm">Save payment</button>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    <% } %>

                                    <% if (!(invoice.receipts || []).length) { %>
                                        <p class="text-muted mb-0">No payments recorded yet.</p>
                                    <% } else { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Date</th>
                                                        <th class="text-end">Amount</th>
                                                        <th>Method</th>
                                                        <th>Reference</th>
                                                        <th>Recorded by</th>
                                                        <% if (canDeletePayments) { %><th class="text-end">Actions</th><% } %>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% (invoice.receipts || []).forEach(function(receipt) { %>
                                                        <tr>
                                                            <td><%= receipt.paymentDate %></td>
                                                            <td class="text-end"><%= formatIndianCurrency(receipt.amount) %></td>
                                                            <td><%= formatPaymentMethod(receipt.paymentMethod) %></td>
                                                            <td><%= receipt.reference || '—' %></td>
                                                            <td><%= receipt.createdBy ? receipt.createdBy.adminName : '—' %></td>
                                                            <% if (canDeletePayments) { %>
                                                                <td class="text-end">
                                                                    <form action="/company/accounts/invoices/<%= invoice.id %>/receipts/<%= receipt.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('Delete this payment? The invoice balance will be recalculated.');">
                                                                        <button type="submit" class="btn btn-soft-danger btn-sm" title="Delete payment">
                                                                            <i class="ri-delete-bin-line"></i> Delete
                                                                        </button>
                                                                    </form>
                                                                </td>
                                                            <% } %>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="card mb-3">
                                <div class="card-header"><h5 class="card-title mb-0">Payment summary</h5></div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2"><span>Total</span><strong><%= formatIndianCurrency(invoice.totalAmount) %></strong></div>
                                    <div class="d-flex justify-content-between mb-2 text-success"><span>Paid</span><strong><%= formatIndianCurrency(invoice.amountPaid) %></strong></div>
                                    <div class="d-flex justify-content-between mb-2 <%= Number(invoice.amountDue) > 0 ? 'text-danger' : '' %>"><span>Due</span><strong><%= formatIndianCurrency(invoice.amountDue) %></strong></div>
                                    <% if (Number(invoice.amountDue) > 0 && Number(invoice.totalAmount) > 0) { %>
                                        <% var paidPct = Math.min(100, Math.round((Number(invoice.amountPaid) / Number(invoice.totalAmount)) * 100)); %>
                                        <div class="progress mt-3" style="height: 8px;">
                                            <div class="progress-bar bg-success" role="progressbar" style="width: <%= paidPct %>%;" aria-valuenow="<%= paidPct %>" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <div class="text-muted fs-12 mt-1"><%= paidPct %>% paid</div>
                                    <% } %>
                                </div>
                            </div>
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><strong><%= formatIndianCurrency(invoice.subtotal) %></strong></div>
                                    <div class="d-flex justify-content-between mb-2"><span>Tax</span><strong><%= formatIndianCurrency(invoice.taxAmount) %></strong></div>
                                    <div class="d-flex justify-content-between mb-2"><span>Discount</span><strong><%= formatIndianCurrency(invoice.discountAmount) %></strong></div>
                                    <hr>
                                    <div class="d-flex justify-content-between fs-5"><span>Total</span><strong><%= formatIndianCurrency(invoice.totalAmount) %></strong></div>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
