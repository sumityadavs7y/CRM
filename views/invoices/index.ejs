<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Invoices - Accounts',
    activeNav: 'accounts-invoices'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Invoices</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item">Accounts & Transactions</li>
                                        <li class="breadcrumb-item active">Invoices</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
                    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

                    <div class="card">
                        <div class="card-header"><h5 class="card-title mb-0">All invoices</h5></div>
                        <div class="card-body">
                            <% if (!invoices.length) { %>
                                <p class="text-muted mb-0">No invoices yet. Convert an accepted quotation to create one.</p>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Number</th>
                                                <th>Customer</th>
                                                <th>Quotation</th>
                                                <th>Issue date</th>
                                                <th class="text-end">Total</th>
                                                <th class="text-end">Paid</th>
                                                <th class="text-end">Due</th>
                                                <th>Status</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% invoices.forEach(function(invoice) { %>
                                                <tr>
                                                    <td><a href="/company/accounts/invoices/<%= invoice.id %>"><%= invoice.invoiceNumber %></a></td>
                                                    <td><%= invoice.customerName %></td>
                                                    <td><%= invoice.quotation ? invoice.quotation.quotationNumber : '—' %></td>
                                                    <td><%= invoice.issueDate %></td>
                                                    <td class="text-end"><%= formatIndianCurrency(invoice.totalAmount) %></td>
                                                    <td class="text-end text-success"><%= formatIndianCurrency(invoice.amountPaid) %></td>
                                                    <td class="text-end"><%= formatIndianCurrency(invoice.amountDue) %></td>
                                                    <td><span class="badge <%= getInvoiceStatusBadgeClass(invoice.status) %>"><%= formatInvoiceStatus(invoice.status) %></span></td>
                                                    <td class="text-nowrap">
                                                        <a href="/company/accounts/invoices/<%= invoice.id %>" class="btn btn-soft-primary btn-sm">View</a>
                                                        <% if (canDeleteInvoice) {
                                                            const invoiceDeleteMessage = 'Delete invoice ' + invoice.invoiceNumber + '? This cannot be undone.'
                                                                + (invoice.quotation
                                                                    ? '\n\nThe linked quotation ' + invoice.quotation.quotationNumber + ' and all payments will also be deleted.'
                                                                    : '\n\nAll payments on this invoice will be deleted.')
                                                                + '\n\nLinked inventory units will be marked as available.';
                                                        %>
                                                            <form action="/company/accounts/invoices/<%= invoice.id %>/delete" method="post" class="d-inline" onsubmit='return confirm(<%- JSON.stringify(invoiceDeleteMessage) %>);'>
                                                                <button type="submit" class="btn btn-soft-danger btn-sm">Delete</button>
                                                            </form>
                                                        <% } %>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
