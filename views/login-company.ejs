<%- include('partials/velzon/auth-layout-open', {
    pageTitle: 'Company Sign In - CRM'
}) %>
                                <div class="text-center mt-2">
                                    <h5 class="text-primary">Company Login</h5>
                                    <p class="text-muted">Sign in with credentials provided by your platform administrator.</p>
                                </div>

                                <% if (error) { %>
                                    <div class="alert alert-danger mt-3 mb-0" role="alert"><%= error %></div>
                                <% } %>

                                <div class="p-2 mt-4">
                                    <form action="/auth/company/login" method="post">
                                        <div class="mb-3">
                                            <label for="email" class="form-label">Company admin email</label>
                                            <input type="email" class="form-control" id="email" name="email" placeholder="admin@company.com" value="<%= email %>" required>
                                        </div>

                                        <div class="mb-3">
                                            <div class="float-end">
                                                <a href="/auth/login" class="text-muted">Platform login</a>
                                            </div>
                                            <label class="form-label" for="password-input">Password</label>
                                            <div class="position-relative auth-pass-inputgroup mb-3">
                                                <input type="password" class="form-control pe-5 password-input" placeholder="Enter password" id="password-input" name="password" required>
                                                <button class="btn btn-link position-absolute end-0 top-0 text-decoration-none text-muted password-addon" type="button" id="password-addon"><i class="ri-eye-fill align-middle"></i></button>
                                            </div>
                                        </div>

                                        <div class="mt-4">
                                            <button class="btn btn-primary w-100" type="submit">Login as Company</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
<%- include('partials/velzon/auth-layout-close', {
    footerLink: '<p class="mb-0">Platform administrator ? <a href="/auth/login" class="fw-semibold text-primary text-decoration-underline"> Sign in here </a></p>'
}) %>
