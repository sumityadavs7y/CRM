<div class="app-menu navbar-menu">
    <div class="navbar-brand-box">
        <%- include('_nav-brand') %>
        <button type="button" class="btn btn-sm p-0 fs-20 header-item float-end btn-vertical-sm-hover" id="vertical-hover">
            <i class="ri-record-circle-line"></i>
        </button>
    </div>

    <div id="scrollbar">
        <div class="container-fluid">
            <div id="two-column-menu"></div>
            <ul class="navbar-nav" id="navbar-nav">
                <li class="menu-title"><span>Menu</span></li>
                <li class="nav-item">
                    <a class="nav-link menu-link<%= typeof activeNav === 'undefined' || activeNav === 'dashboard' ? ' active' : '' %>" href="/dashboard">
                        <i class="ri-dashboard-2-line"></i> <span>Dashboard</span>
                    </a>
                </li>
                <% if (user && user.authType === 'company' && user.can && user.can('access_demo', 'view')) { %>
                    <li class="nav-item">
                        <a class="nav-link menu-link<%= activeNav === 'access-demo' ? ' active' : '' %>" href="/access-demo">
                            <i class="ri-shield-keyhole-line"></i> <span>Access Demo</span>
                        </a>
                    </li>
                <% } %>
                <% const canViewUsers = user && user.can && user.can('user_management', 'view'); %>
                <% const canViewRoles = user && user.can && user.can('role_management', 'view'); %>
                <% const userMgmtActive = activeNav === 'company-users' || activeNav === 'company-roles'; %>
                <% if (canViewUsers || canViewRoles) { %>
                    <li class="nav-item">
                        <a class="nav-link menu-link" href="#sidebarUserManagement" data-bs-toggle="collapse" role="button" aria-expanded="<%= userMgmtActive ? 'true' : 'false' %>" aria-controls="sidebarUserManagement">
                            <i class="ri-team-line"></i> <span>User Management</span>
                        </a>
                        <div class="collapse menu-dropdown<%= userMgmtActive ? ' show' : '' %>" id="sidebarUserManagement">
                            <ul class="nav nav-sm flex-column">
                                <% if (canViewUsers) { %>
                                    <li class="nav-item">
                                        <a href="/company/users" class="nav-link<%= activeNav === 'company-users' ? ' active' : '' %>">Users</a>
                                    </li>
                                <% } %>
                                <% if (canViewRoles) { %>
                                    <li class="nav-item">
                                        <a href="/company/roles" class="nav-link<%= activeNav === 'company-roles' ? ' active' : '' %>">Roles</a>
                                    </li>
                                <% } %>
                            </ul>
                        </div>
                    </li>
                <% } %>
                <% const canViewCrmSetup = user && user.can && user.can('crm_setup', 'view'); %>
                <% const canViewLeads = user && user.can && user.can('leads', 'view'); %>
                <% const isLeadsActive = activeNav === 'leads' || activeNav === 'leads-reports'; %>
                <% if (canViewLeads) { %>
                    <li class="nav-item">
                        <a class="nav-link menu-link" href="#sidebarLeads" data-bs-toggle="collapse" role="button" aria-expanded="<%= isLeadsActive ? 'true' : 'false' %>" aria-controls="sidebarLeads">
                            <i class="ri-user-search-line"></i> <span>Leads</span>
                        </a>
                        <div class="collapse menu-dropdown<%= isLeadsActive ? ' show' : '' %>" id="sidebarLeads">
                            <ul class="nav nav-sm flex-column">
                                <li class="nav-item">
                                    <a href="/company/leads" class="nav-link<%= activeNav === 'leads' ? ' active' : '' %>">All Leads</a>
                                </li>
                                <li class="nav-item">
                                    <a href="/company/leads/reports" class="nav-link<%= activeNav === 'leads-reports' ? ' active' : '' %>">Reports</a>
                                </li>
                            </ul>
                        </div>
                    </li>
                <% } %>
                <% const canViewProjects = user && user.can && user.can('project_management', 'view'); %>
                <% if (canViewProjects) { %>
                    <li class="nav-item">
                        <a class="nav-link menu-link<%= activeNav === 'projects' ? ' active' : '' %>" href="/company/projects">
                            <i class="ri-building-4-line"></i> <span>Project Management</span>
                        </a>
                    </li>
                <% } %>
                <% const canViewMedia = user && user.can && user.can('media_library', 'view'); %>
                <% if (canViewMedia) { %>
                    <li class="nav-item">
                        <a class="nav-link menu-link<%= activeNav === 'media-library' ? ' active' : '' %>" href="/company/media">
                            <i class="ri-gallery-line"></i> <span>Media Library</span>
                        </a>
                    </li>
                <% } %>
                <% const isCrmSetupActive = activeNav === 'crm-setup-pipelines' || activeNav === 'crm-setup-sources'; %>
                <% if (canViewCrmSetup) { %>
                    <li class="nav-item">
                        <a class="nav-link menu-link" href="#sidebarCrmSetup" data-bs-toggle="collapse" role="button" aria-expanded="<%= isCrmSetupActive ? 'true' : 'false' %>" aria-controls="sidebarCrmSetup">
                            <i class="ri-settings-3-line"></i> <span>CRM Setup</span>
                        </a>
                        <div class="collapse menu-dropdown<%= isCrmSetupActive ? ' show' : '' %>" id="sidebarCrmSetup">
                            <ul class="nav nav-sm flex-column">
                                <li class="nav-item">
                                    <a href="/company/crm-setup/pipelines" class="nav-link<%= activeNav === 'crm-setup-pipelines' ? ' active' : '' %>">Pipelines</a>
                                </li>
                                <li class="nav-item">
                                    <a href="/company/crm-setup/sources" class="nav-link<%= activeNav === 'crm-setup-sources' ? ' active' : '' %>">Sources</a>
                                </li>
                            </ul>
                        </div>
                    </li>
                <% } %>
                <% if (user && user.isSuperAdmin) { %>
                    <li class="nav-item">
                        <a class="nav-link menu-link<%= activeNav === 'subscription-plans' ? ' active' : '' %>" href="/subscription-plans">
                            <i class="ri-vip-crown-line"></i> <span>Subscription Plans</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link menu-link<%= activeNav === 'companies' ? ' active' : '' %>" href="/companies">
                            <i class="ri-building-line"></i> <span>Companies</span>
                        </a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>

    <div class="sidebar-background"></div>
</div>
<div class="vertical-overlay"></div>
