<div class="media-library<%= typeof pickerMode !== 'undefined' && pickerMode ? ' media-library--picker' : '' %>" id="<%= typeof pickerMode !== 'undefined' && pickerMode ? 'mediaPickerRoot' : 'mediaLibraryRoot' %>" data-picker-mode="<%= typeof pickerMode !== 'undefined' && pickerMode ? 'true' : 'false' %>">
    <div class="media-library__layout">
        <aside class="media-library__sidebar">
            <div class="media-library__sidebar-section">
                <div class="media-library__sidebar-title">Quick Access</div>
                <button type="button" class="media-library__nav-item media-library__nav-item--active" data-folder-id="all">
                    <span class="media-library__nav-icon"><i class="ri-folder-2-line"></i></span>
                    <span class="media-library__nav-label">All Files</span>
                    <span class="badge bg-success-subtle text-success" id="mediaAllFilesCount">0</span>
                </button>
            </div>

            <div class="media-library__sidebar-section media-library__sidebar-section--grow">
                <div class="media-library__sidebar-title media-library__sidebar-title--row">
                    <span>Folders</span>
                    <% if (typeof canEdit !== 'undefined' && canEdit) { %>
                        <button type="button" class="btn btn-sm btn-ghost-success p-0" id="mediaCreateFolderBtn" title="Create folder">
                            <i class="ri-add-line fs-16"></i>
                        </button>
                    <% } %>
                </div>
                <div class="media-library__folder-list" id="mediaFolderList"></div>
            </div>

            <div class="media-library__storage" id="mediaStorageStats">
                <div class="media-library__storage-row">
                    <span><i class="ri-hard-drive-2-line me-1"></i> Used Space</span>
                    <strong id="mediaUsedSpace">0 B</strong>
                </div>
                <div class="media-library__storage-row">
                    <span>Available</span>
                    <strong id="mediaAvailableSpace">0 B</strong>
                </div>
                <div class="progress media-library__storage-progress">
                    <div class="progress-bar bg-success" id="mediaStorageProgress" role="progressbar" style="width: 0%"></div>
                </div>
            </div>
        </aside>

        <section class="media-library__main">
            <div class="media-library__toolbar">
                <div class="media-library__toolbar-left">
                    <div class="media-library__search">
                        <i class="ri-search-line"></i>
                        <input type="search" class="form-control" id="mediaSearchInput" placeholder="Search media files..." autocomplete="off">
                    </div>
                </div>
                <div class="media-library__toolbar-right">
                    <div class="btn-group media-library__view-toggle" role="group" aria-label="View type">
                        <button type="button" class="btn btn-light active" data-view="grid" title="Grid view"><i class="ri-grid-fill"></i></button>
                        <button type="button" class="btn btn-light" data-view="list" title="List view"><i class="ri-list-check"></i></button>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-light dropdown-toggle" type="button" id="mediaSortDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            Date ↓
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" id="mediaSortMenu"></ul>
                    </div>
                    <div class="media-library__badges">
                        <span class="badge bg-light text-body" id="mediaViewFileCount">0 Files</span>
                        <span class="badge bg-light text-body" id="mediaViewTotalSize">0 B</span>
                        <span class="badge bg-light text-body" id="mediaViewImageCount">0 Images</span>
                    </div>
                    <% if (typeof canEdit !== 'undefined' && canEdit) { %>
                        <button type="button" class="btn btn-success<%= typeof pickerMode !== 'undefined' && pickerMode ? ' d-none' : '' %>" id="mediaUploadBtn">
                            <i class="ri-upload-2-line me-1"></i> Upload Files
                        </button>
                        <input type="file" id="mediaUploadInput" class="d-none" multiple>
                    <% } %>
                </div>
            </div>

            <div class="media-library__content" id="mediaContentArea">
                <div class="media-library__loading" id="mediaLoadingState">
                    <div class="spinner-border text-success" role="status"><span class="visually-hidden">Loading...</span></div>
                </div>
                <div class="media-library__grid" id="mediaGridView"></div>
                <div class="media-library__list d-none" id="mediaListView">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Size</th>
                                    <th>Date</th>
                                    <% if (typeof canEdit !== 'undefined' && canEdit && (typeof pickerMode === 'undefined' || !pickerMode)) { %>
                                        <th class="text-end">Actions</th>
                                    <% } %>
                                </tr>
                            </thead>
                            <tbody id="mediaListBody"></tbody>
                        </table>
                    </div>
                </div>
                <div class="media-library__empty d-none" id="mediaEmptyState">
                    <i class="ri-image-line"></i>
                    <p class="mb-0">No files found in this view.</p>
                </div>
            </div>
        </section>
    </div>
</div>
