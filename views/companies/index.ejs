<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Companies - CRM',
    activeNav: 'companies'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Companies</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item active">Companies</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Company Login Subscriptions</h4>
                                    <div class="flex-shrink-0 d-flex gap-2">
                                        <a href="/subscription-plans" class="btn btn-soft-primary btn-sm">Manage Plans</a>
                                        <a href="/companies/new" class="btn btn-success btn-sm">
                                            <i class="ri-add-line align-middle me-1"></i> Create Company Login
                                        </a>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <% if (companies.length === 0) { %>
                                        <p class="text-muted mb-0">No companies yet. Create a company login — a subscription plan can be assigned later when editing.</p>
                                    <% } else { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Company</th>
                                                        <th>Primary Admin</th>
                                                        <th>Login Email</th>
                                                        <th>Plan</th>
                                                        <th>Valid Until</th>
                                                        <th>Subscription</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% companies.forEach(function(company) { %>
                                                        <% const subStatus = formatSubscriptionStatus(company.subscription); %>
                                                        <% const primaryAdmin = getPrimaryAdmin(company.credentials); %>
                                                        <tr>
                                                            <td class="fw-medium"><%= company.name %></td>
                                                            <td><%= primaryAdmin ? primaryAdmin.adminName : '—' %></td>
                                                            <td><%= primaryAdmin ? primaryAdmin.email : '—' %></td>
                                                            <td><%= company.subscription && company.subscription.plan ? company.subscription.plan.name : '—' %></td>
                                                            <td><%= company.subscription ? new Date(company.subscription.expiresAt).toLocaleDateString() : '—' %></td>
                                                            <td><span class="badge <%= subStatus.className %>"><%= subStatus.label %></span></td>
                                                            <td class="text-nowrap">
                                                                <a href="/companies/<%= company.id %>" class="btn btn-soft-secondary btn-sm">View</a>
                                                                <a href="/companies/<%= company.id %>/edit" class="btn btn-soft-primary btn-sm">Edit</a>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
