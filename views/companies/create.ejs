<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Create Company - CRM',
    activeNav: 'companies'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Create Company Login</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item"><a href="/companies">Companies</a></li>
                                        <li class="breadcrumb-item active">Create</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row justify-content-center">
                        <div class="col-lg-8">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Company & Primary Admin Login</h4>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted">Create the company and primary admin credentials. A subscription plan is optional and can be assigned later when editing the company.</p>

                                    <% if (error) { %>
                                        <div class="alert alert-danger" role="alert"><%= error %></div>
                                    <% } %>

                                    <form action="/companies" method="post">
                                        <div class="mb-3">
                                            <label for="companyName" class="form-label">Company name</label>
                                            <input type="text" class="form-control" id="companyName" name="companyName" placeholder="Acme Corporation" value="<%= values.companyName || '' %>" required>
                                        </div>

                                        <hr class="my-4">
                                        <h5 class="mb-3">Primary Admin Credentials</h5>

                                        <div class="mb-3">
                                            <label for="adminName" class="form-label">Primary admin name</label>
                                            <input type="text" class="form-control" id="adminName" name="adminName" placeholder="Jane Smith" value="<%= values.adminName || '' %>" required>
                                        </div>

                                        <div class="mb-3">
                                            <label for="email" class="form-label">Login email</label>
                                            <input type="email" class="form-control" id="email" name="email" placeholder="admin@acme.com" value="<%= values.email || '' %>" required>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label" for="password-input">Password</label>
                                            <input type="password" class="form-control" id="password-input" name="password" placeholder="Enter password" required>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label" for="confirm-password-input">Confirm password</label>
                                            <input type="password" class="form-control" id="confirm-password-input" name="confirmPassword" placeholder="Repeat password" required>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <button class="btn btn-success" type="submit">Create Company Login</button>
                                            <a href="/companies" class="btn btn-light">Cancel</a>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
