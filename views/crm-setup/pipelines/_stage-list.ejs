<% if (!canEdit) { %>
    <% if (stages.length === 0) { %>
        <p class="text-muted mb-0">No stages configured.</p>
    <% } else { %>
        <table class="pipeline-config-table table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 48px;">#</th>
                    <th>Name</th>
                </tr>
            </thead>
            <tbody>
                <% stages.forEach(function(stage, index) { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= stage.name %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
<% } else { %>
    <% const saveLabel = stageType === 'lead' ? 'Save Lead Stages' : 'Save Deal Stages'; %>
    <form method="post"
          action="/company/crm-setup/pipelines/<%= pipelineId %>/stages/sync"
          class="pipeline-tab-form"
          data-tab-type="stage"
          data-stage-type="<%= stageType %>">
        <input type="hidden" name="stageType" value="<%= stageType %>">

        <table class="pipeline-config-table table table-sm align-middle mb-3">
            <thead class="table-light">
                <tr>
                    <th style="width: 48px;">#</th>
                    <th>Name</th>
                    <th style="width: 80px;">Actions</th>
                </tr>
            </thead>
            <tbody data-row-container>
                <% if (stages.length === 0) { %>
                    <tr class="pipeline-empty-row">
                        <td colspan="3" class="text-muted">No stages yet. Add one below.</td>
                    </tr>
                <% } else { %>
                    <% stages.forEach(function(stage, index) { %>
                        <tr data-row data-row-id="<%= stage.id %>">
                            <td class="row-index"><%= index + 1 %></td>
                            <td>
                                <input type="hidden" name="stages[<%= index %>][id]" value="<%= stage.id %>">
                                <input type="text"
                                       class="form-control form-control-sm pipeline-field-input"
                                       name="stages[<%= index %>][name]"
                                       value="<%= stage.name %>"
                                       required>
                            </td>
                            <td>
                                <button type="button" class="btn btn-soft-danger btn-sm btn-delete-row">Delete</button>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>

        <template data-row-template>
            <tr data-row data-row-id="">
                <td class="row-index"></td>
                <td>
                    <input type="hidden" name="stages[__index__][id]" value="">
                    <input type="text"
                           class="form-control form-control-sm pipeline-field-input"
                           name="stages[__index__][name]"
                           placeholder="New <%= stageType %> stage name"
                           required>
                </td>
                <td>
                    <button type="button" class="btn btn-soft-danger btn-sm btn-delete-row">Delete</button>
                </td>
            </tr>
        </template>

        <div class="d-flex gap-2 flex-wrap align-items-center mb-3">
            <button type="button" class="btn btn-sm btn-soft-primary btn-add-row">Add Stage</button>
            <button type="submit" class="btn btn-sm btn-success"><%= saveLabel %></button>
        </div>
    </form>
<% } %>
