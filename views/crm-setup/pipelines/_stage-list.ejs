<% if (stages.length === 0) { %>
    <p class="text-muted mb-3">No stages configured.</p>
<% } else { %>
    <div class="table-responsive mb-3">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 60px;">#</th>
                    <th>Name</th>
                    <% if (canEdit) { %>
                        <th style="width: 160px;">Actions</th>
                    <% } %>
                </tr>
            </thead>
            <tbody>
                <% stages.forEach(function(stage, index) { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td>
                            <% if (canEdit) { %>
                                <form action="/company/crm-setup/pipelines/<%= pipelineId %>/stages/<%= stage.id %>/edit" method="post" class="d-flex gap-2 align-items-center">
                                    <input type="hidden" name="sortOrder" value="<%= stage.sortOrder %>">
                                    <input type="text" class="form-control form-control-sm" name="name" value="<%= stage.name %>" required>
                                    <button type="submit" class="btn btn-sm btn-soft-success">Save</button>
                                </form>
                            <% } else { %>
                                <%= stage.name %>
                            <% } %>
                        </td>
                        <% if (canEdit) { %>
                            <td>
                                <form action="/company/crm-setup/pipelines/<%= pipelineId %>/stages/<%= stage.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('Delete this stage?');">
                                    <button type="submit" class="btn btn-sm btn-soft-danger">Delete</button>
                                </form>
                            </td>
                        <% } %>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } %>

<% if (canEdit) { %>
    <form action="/company/crm-setup/pipelines/<%= pipelineId %>/stages" method="post" class="d-flex gap-2">
        <input type="hidden" name="stageType" value="<%= stageType %>">
        <input type="text" class="form-control form-control-sm" name="name" placeholder="New <%= stageType %> stage name" required>
        <button type="submit" class="btn btn-sm btn-success">Add Stage</button>
    </form>
<% } %>
