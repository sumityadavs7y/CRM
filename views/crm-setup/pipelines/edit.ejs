<%
    const selectedName = values.name !== undefined ? values.name : pipeline.name;
    const selectedDescription = values.description !== undefined ? values.description : (pipeline.description || '');
%>

<%- include('../../partials/velzon/app-layout-open', {
    pageTitle: 'Edit Pipeline - CRM Setup',
    activeNav: 'crm-setup-pipelines'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Edit Pipeline</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item">CRM Setup</li>
                                        <li class="breadcrumb-item"><a href="/company/crm-setup/pipelines">Pipelines</a></li>
                                        <li class="breadcrumb-item active">Edit</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <% if (error) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-danger" role="alert"><%= error %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row mb-3">
                        <div class="col-12 d-flex gap-2">
                            <a href="/company/crm-setup/pipelines" class="btn btn-light btn-sm">Back to Pipelines</a>
                            <a href="/company/crm-setup/pipelines/<%= pipeline.id %>" class="btn btn-soft-primary btn-sm">View Pipeline</a>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h5 class="card-title mb-0 flex-grow-1">Pipeline Details</h5>
                                </div>
                                <div class="card-body">
                                    <form action="/company/crm-setup/pipelines/<%= pipeline.id %>/edit" method="post">
                                        <div class="mb-3">
                                            <label for="name" class="form-label">Pipeline name</label>
                                            <input type="text" class="form-control" id="name" name="name" value="<%= selectedName %>" required>
                                        </div>

                                        <div class="mb-4">
                                            <label for="description" class="form-label">Description</label>
                                            <textarea class="form-control" id="description" name="description" rows="3" placeholder="Optional description for this pipeline"><%= selectedDescription %></textarea>
                                        </div>

                                        <button class="btn btn-success" type="submit">Save Pipeline</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <%- include('_pipeline-config-tabs', {
                                pipeline: pipeline,
                                dealStages: dealStages,
                                labels: labels,
                                canEdit: true,
                                activeTab: activeTab,
                                defaultLabelColor: defaultLabelColor
                            }) %>
                        </div>
                    </div>

<%- include('../../partials/velzon/app-layout-close') %>
