<% if (!canEdit) { %>
    <% if (labels.length === 0) { %>
        <p class="text-muted mb-0">No labels configured.</p>
    <% } else { %>
        <table class="pipeline-config-table table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 48px;">#</th>
                    <th style="width: 80px;">Color</th>
                    <th>Name</th>
                </tr>
            </thead>
            <tbody>
                <% labels.forEach(function(label, index) { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td>
                            <span class="color-preview" style="background: <%= label.color %>;" title="<%= label.color %>"></span>
                        </td>
                        <td>
                            <span class="badge rounded-pill px-2 py-1" style="background: <%= label.color %>; color: #fff;"><%= label.name %></span>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
<% } else { %>
    <form method="post"
          action="/company/crm-setup/pipelines/<%= pipelineId %>/labels/sync"
          class="pipeline-tab-form"
          data-tab-type="label"
          data-default-color="<%= defaultLabelColor %>">

        <table class="pipeline-config-table table table-sm align-middle mb-3">
            <thead class="table-light">
                <tr>
                    <th style="width: 48px;">#</th>
                    <th style="width: 80px;">Color</th>
                    <th>Name</th>
                    <th style="width: 80px;">Actions</th>
                </tr>
            </thead>
            <tbody data-row-container>
                <% if (labels.length === 0) { %>
                    <tr class="pipeline-empty-row">
                        <td colspan="4" class="text-muted">No labels yet. Add one below.</td>
                    </tr>
                <% } else { %>
                    <% labels.forEach(function(label, index) { %>
                        <tr data-row data-row-id="<%= label.id %>">
                            <td class="row-index"><%= index + 1 %></td>
                            <td>
                                <button type="button"
                                        class="color-picker-trigger color-preview"
                                        style="background: <%= label.color %>;"
                                        title="Choose color"
                                        aria-label="Choose color for <%= label.name %>"></button>
                                <input type="hidden" name="labels[<%= index %>][color]" value="<%= label.color %>">
                            </td>
                            <td>
                                <input type="hidden" name="labels[<%= index %>][id]" value="<%= label.id %>">
                                <input type="text"
                                       class="form-control form-control-sm pipeline-field-input"
                                       name="labels[<%= index %>][name]"
                                       value="<%= label.name %>"
                                       required>
                            </td>
                            <td>
                                <button type="button" class="btn btn-soft-danger btn-sm btn-delete-row">Delete</button>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>

        <template data-row-template>
            <tr data-row data-row-id="">
                <td class="row-index"></td>
                <td>
                    <button type="button"
                            class="color-picker-trigger color-preview"
                            style="background: <%= defaultLabelColor %>;"
                            title="Choose color"
                            aria-label="Choose label color"></button>
                    <input type="hidden" name="labels[__index__][color]" value="<%= defaultLabelColor %>">
                </td>
                <td>
                    <input type="hidden" name="labels[__index__][id]" value="">
                    <input type="text"
                           class="form-control form-control-sm pipeline-field-input"
                           name="labels[__index__][name]"
                           placeholder="New label name"
                           required>
                </td>
                <td>
                    <button type="button" class="btn btn-soft-danger btn-sm btn-delete-row">Delete</button>
                </td>
            </tr>
        </template>

        <div class="d-flex gap-2 flex-wrap align-items-center mb-3">
            <button type="button" class="btn btn-sm btn-soft-primary btn-add-row">Add Label</button>
            <button type="submit" class="btn btn-sm btn-success">Save Labels</button>
        </div>
    </form>

    <script src="/js/iro.min.js"></script>
    <script src="/js/pipeline-color-picker.js"></script>
<% } %>
