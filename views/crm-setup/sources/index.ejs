<%- include('../../partials/velzon/app-layout-open', {
    pageTitle: 'Sources - CRM Setup',
    activeNav: 'crm-setup-sources'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Sources</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item">CRM Setup</li>
                                        <li class="breadcrumb-item active">Sources</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <% if (error) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-danger" role="alert"><%= error %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Lead Sources</h4>
                                    <% if (user.can('crm_setup', 'edit')) { %>
                                        <div class="flex-shrink-0">
                                            <a href="/company/crm-setup/sources/edit" class="btn btn-soft-secondary btn-sm">
                                                <i class="ri-pencil-line align-middle me-1"></i> Edit Sources
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted">Sources describe where leads and opportunities originate. Each company maintains its own list.</p>

                                    <% if (sources.length === 0) { %>
                                        <p class="text-muted mb-0">No sources configured.</p>
                                    <% } else { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th style="width: 48px;">#</th>
                                                        <th>Name</th>
                                                        <th>Type</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% sources.forEach(function(source, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= source.name %></td>
                                                            <td>
                                                                <% if (source.isSystem) { %>
                                                                    <span class="badge bg-soft-secondary text-secondary">Default</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-soft-primary text-primary">Custom</span>
                                                                <% } %>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../../partials/velzon/app-layout-close') %>
