<div class="modal fade" id="mediaFilePreviewModal" tabindex="-1" aria-labelledby="mediaFilePreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-truncate pe-3" id="mediaFilePreviewModalLabel">File Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body media-library-preview__body" id="mediaFilePreviewBody">
                <div class="media-library-preview__loading text-center py-5">
                    <div class="spinner-border text-success" role="status"><span class="visually-hidden">Loading...</span></div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="me-auto small text-muted text-truncate" id="mediaFilePreviewMeta"></div>
                <a href="#" class="btn btn-light" id="mediaFilePreviewDownload" target="_blank" rel="noopener noreferrer">Open / Download</a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
