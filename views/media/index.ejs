<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Media Library - CRM',
    activeNav: 'media-library'
}) %>

                    <div class="media-library-page">
                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Manage Media Library</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item active">Media Library</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row media-library-page__content flex-grow-1">
                        <div class="col-12">
                            <div class="card media-library-card h-100">
                                <div class="card-body p-0 h-100">
                                    <%- include('../partials/media/_media-browser', {
                                        pickerMode: false,
                                        canEdit: canEdit
                                    }) %>
                                </div>
                            </div>
                        </div>
                    </div>
                    </div>

                    <% if (canEdit) { %>
                        <%- include('./_folder-modal') %>
                        <%- include('./_delete-confirm-modal') %>
                    <% } %>
                    <%- include('./_file-preview-modal') %>

                    <script type="application/json" id="mediaLibraryConfig"><%- JSON.stringify({
                        sortOptions: sortOptions,
                        defaultSort: defaultSort,
                        defaultView: defaultView,
                        canEdit: canEdit,
                        pickerMode: false
                    }) %></script>

<%- include('../partials/velzon/app-layout-close') %>
