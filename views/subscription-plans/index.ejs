<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Subscription Plans - CRM',
    activeNav: 'subscription-plans'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Subscription Plans</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item active">Subscription Plans</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Subscription Plans</h4>
                                    <div class="flex-shrink-0">
                                        <a href="/subscription-plans/new" class="btn btn-success btn-sm">
                                            <i class="ri-add-line align-middle me-1"></i> Create Plan
                                        </a>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted">Define limits and enabled features for company subscriptions. Validity is set when assigning a plan to a company.</p>

                                    <% if (plans.length === 0) { %>
                                        <p class="text-muted mb-0">No subscription plans yet.</p>
                                    <% } else { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Plan</th>
                                                        <th>Limits</th>
                                                        <th>Features</th>
                                                        <th>Status</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% plans.forEach(function(plan) { %>
                                                        <tr>
                                                            <td>
                                                                <div class="fw-medium"><%= plan.name %></div>
                                                                <% if (plan.description) { %>
                                                                    <small class="text-muted"><%= plan.description %></small>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <small class="text-muted d-block">Users: <%= plan.maxUsers %></small>
                                                                <small class="text-muted d-block">Contacts: <%= plan.maxContacts %></small>
                                                                <small class="text-muted d-block">Deals: <%= plan.maxDeals %></small>
                                                                <small class="text-muted d-block">Storage: <%= plan.maxStorageMb %> MB</small>
                                                            </td>
                                                            <td>
                                                                <% if (plan.features && plan.features.length) { %>
                                                                    <% plan.features.forEach(function(featureKey) { %>
                                                                        <span class="badge bg-primary-subtle text-primary me-1 mb-1"><%= getFeatureLabel(featureKey) %></span>
                                                                    <% }); %>
                                                                <% } else { %>
                                                                    <span class="text-muted">None</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <% if (plan.isActive) { %>
                                                                    <span class="badge bg-success-subtle text-success">Active</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                                                <% } %>
                                                            </td>
                                                            <td class="text-nowrap">
                                                                <a href="/subscription-plans/<%= plan.id %>" class="btn btn-soft-secondary btn-sm">View</a>
                                                                <a href="/subscription-plans/<%= plan.id %>/edit" class="btn btn-soft-primary btn-sm">Edit</a>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
