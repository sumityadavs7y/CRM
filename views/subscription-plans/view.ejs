<%- include('../partials/velzon/app-layout-open', {
    pageTitle: plan.name + ' - CRM',
    activeNav: 'subscription-plans'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0"><%= plan.name %></h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item"><a href="/subscription-plans">Subscription Plans</a></li>
                                        <li class="breadcrumb-item active">View</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row justify-content-center">
                        <div class="col-lg-9">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Plan Details</h4>
                                    <div class="flex-shrink-0 d-flex gap-2">
                                        <a href="/subscription-plans/<%= plan.id %>/edit" class="btn btn-soft-primary btn-sm">Edit</a>
                                        <a href="/subscription-plans" class="btn btn-light btn-sm">Back</a>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <h5 class="mb-3">General</h5>
                                    <div class="table-responsive mb-4">
                                        <table class="table table-borderless mb-0">
                                            <tbody>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal" style="width: 180px;">Plan name</th>
                                                    <td class="fw-medium"><%= plan.name %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal">Description</th>
                                                    <td><%= plan.description || '—' %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal">Status</th>
                                                    <td>
                                                        <% if (plan.isActive) { %>
                                                            <span class="badge bg-success-subtle text-success">Active</span>
                                                        <% } else { %>
                                                            <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                                        <% } %>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal">Created</th>
                                                    <td><%= new Date(plan.createdAt).toLocaleString() %></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <hr class="my-4">
                                    <h5 class="mb-3">Limits</h5>
                                    <div class="table-responsive mb-4">
                                        <table class="table table-borderless mb-0">
                                            <tbody>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal" style="width: 180px;">Max users</th>
                                                    <td><%= plan.maxUsers %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal">Max contacts</th>
                                                    <td><%= plan.maxContacts %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal">Max deals</th>
                                                    <td><%= plan.maxDeals %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-0 text-muted fw-normal">Storage</th>
                                                    <td><%= plan.maxStorageMb %> MB</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <hr class="my-4">
                                    <h5 class="mb-3">Features</h5>
                                    <% if (plan.features && plan.features.length) { %>
                                        <% plan.features.forEach(function(featureKey) { %>
                                            <span class="badge bg-primary-subtle text-primary me-1 mb-1"><%= getFeatureLabel(featureKey) %></span>
                                        <% }); %>
                                    <% } else { %>
                                        <p class="text-muted mb-0">No features enabled.</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
