<div class="modal fade" id="leadCommunicationModal" tabindex="-1" aria-labelledby="leadCommunicationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="leadCommunicationModalLabel">Add Email / Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="leadCommunicationForm">
                <input type="hidden" id="leadCommunicationCommId" value="">
                <div class="modal-body">
                    <div id="leadCommunicationFormError" class="alert alert-danger d-none" role="alert"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="modalItemType" class="form-label">Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="modalItemType" name="itemType" required>
                                <option value="">Select type</option>
                                <option value="email">Email</option>
                                <option value="message">Message</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="modalSentAt" class="form-label">Sent at <span class="text-danger">*</span></label>
                            <input type="datetime-local" class="form-control" id="modalSentAt" name="sentAt" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="modalToAddress" class="form-label">To <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="modalToAddress" name="toAddress" required>
                    </div>
                    <div class="mb-3">
                        <label for="modalCommSubject" class="form-label">Subject <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="modalCommSubject" name="subject" required>
                    </div>
                    <div class="mb-3">
                        <label for="modalDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="modalDescription" name="description" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="leadCommunicationSubmit">Add</button>
                </div>
            </form>
        </div>
    </div>
</div>
