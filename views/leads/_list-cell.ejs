<td<% if (column.key === 'customerName') { %> class="fw-medium"<% } %> data-lead-column="<%= column.key %>">
    <% if (column.key === 'customerName') { %>
        <%= lead.customerName %>
    <% } else if (column.key === 'email') { %>
        <%= lead.email %>
    <% } else if (column.key === 'subject') { %>
        <%= lead.subject %>
    <% } else if (column.key === 'assignee') { %>
        <%= lead.assignee ? lead.assignee.adminName : '—' %>
    <% } else if (column.key === 'phone') { %>
        <%= lead.phone || '—' %>
    <% } else if (column.key === 'followUpDate') { %>
        <%= lead.followUpDate || '—' %>
    <% } else if (column.key === 'score') { %>
        <%= lead.score ?? '—' %>
    <% } else if (column.key === 'quality') { %>
        <% if (lead.quality) { %>
            <span class="badge <%= getLeadQualityBadgeClass(lead.quality) %>"><%= formatLeadQuality(lead.quality) %></span>
        <% } else { %>
            —
        <% } %>
    <% } else if (column.key === 'pipeline') { %>
        <%= lead.pipeline ? lead.pipeline.name : '—' %>
    <% } else if (column.key === 'stage') { %>
        <%= lead.stage ? lead.stage.name : '—' %>
    <% } else if (column.key === 'notes') { %>
        <%= formatLeadListNotesPreview(lead.notes) %>
    <% } else if (column.key === 'sources') { %>
        <%= formatLeadListSources(lead.sources) %>
    <% } else if (column.key === 'createdAt') { %>
        <%= formatLeadListDate(lead.createdAt) %>
    <% } else if (column.key === 'updatedAt') { %>
        <%= formatLeadListDate(lead.updatedAt) %>
    <% } else if (column.key === 'communicationCount') { %>
        <%= formatLeadListCount(lead.get ? lead.get('communicationCount') : lead.communicationCount) %>
    <% } else if (column.key === 'taskCount') { %>
        <%= formatLeadListCount(lead.get ? lead.get('taskCount') : lead.taskCount) %>
    <% } else if (column.key === 'discussionCount') { %>
        <%= formatLeadListCount(lead.get ? lead.get('discussionCount') : lead.discussionCount) %>
    <% } %>
</td>
