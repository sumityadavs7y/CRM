<div class="mb-3">
    <label for="customerName" class="form-label">Customer name <span class="text-danger">*</span></label>
    <input type="text" class="form-control" id="customerName" name="customerName" value="<%= values.customerName || '' %>" required>
</div>

<div class="mb-3">
    <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
    <input type="email" class="form-control" id="email" name="email" value="<%= values.email || '' %>" required>
</div>

<div class="mb-3">
    <label for="subject" class="form-label">Subject <span class="text-danger">*</span></label>
    <input type="text" class="form-control" id="subject" name="subject" value="<%= values.subject || '' %>" required>
</div>

<div class="mb-3">
    <label for="assigneeId" class="form-label">Assignee <span class="text-danger">*</span></label>
    <select class="form-select" id="assigneeId" name="assigneeId" required>
        <option value="">Select assignee</option>
        <% assignees.forEach(function(member) { %>
            <option value="<%= member.id %>" <%= String(values.assigneeId || '') === String(member.id) ? 'selected' : '' %>><%= member.adminName %></option>
        <% }); %>
    </select>
</div>

<div class="mb-3">
    <label for="phone" class="form-label">Phone</label>
    <input type="text" class="form-control" id="phone" name="phone" value="<%= values.phone || '' %>">
</div>

<div class="mb-3">
    <label for="followUpDate" class="form-label">Follow-up date</label>
    <input type="date" class="form-control" id="followUpDate" name="followUpDate" value="<%= values.followUpDate || '' %>">
</div>

<div class="mb-3">
    <label for="score" class="form-label">Score</label>
    <input type="number" class="form-control" id="score" name="score" min="1" max="10" step="1" value="<%= values.score !== '' && values.score !== null && values.score !== undefined ? values.score : '' %>">
    <div class="form-text">Optional rating from 1 to 10.</div>
</div>

<div class="mb-3">
    <label for="quality" class="form-label">Quality</label>
    <select class="form-select" id="quality" name="quality">
        <option value="">None</option>
        <% qualityOptions.forEach(function(option) { %>
            <option value="<%= option.value %>" <%= String(values.quality || '') === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }); %>
    </select>
</div>

<div class="mb-3">
    <label for="pipelineId" class="form-label">Pipeline</label>
    <select class="form-select" id="pipelineId" name="pipelineId">
        <option value="">None</option>
        <% pipelines.forEach(function(pipeline) { %>
            <option value="<%= pipeline.id %>" <%= String(values.pipelineId || '') === String(pipeline.id) ? 'selected' : '' %>><%= pipeline.name %></option>
        <% }); %>
    </select>
</div>

<div class="mb-3">
    <label for="stageId" class="form-label">Stage</label>
    <select class="form-select" id="stageId" name="stageId">
        <option value="">None</option>
    </select>
    <div class="form-text">Lead stages for the selected pipeline.</div>
</div>

<div class="mb-3">
    <label for="sourceIds" class="form-label">Sources</label>
    <% if (sources.length === 0) { %>
        <p class="text-muted small mb-0">No sources configured yet.</p>
    <% } else { %>
        <select id="sourceIds" name="sourceIds" multiple placeholder="Search sources...">
            <% sources.forEach(function(source) { %>
                <option value="<%= source.id %>" <%= (values.sourceIds || []).includes(String(source.id)) ? 'selected' : '' %>><%= source.name %></option>
            <% }); %>
        </select>
    <% } %>
</div>

<div class="mb-4">
    <label for="notes" class="form-label">Notes</label>
    <div id="leadCreateNotesEditor" class="lead-notes-editor"><%- values.notes || '' %></div>
    <input type="hidden" name="notes" id="notesInput" value="">
</div>

<script type="application/json" id="lead-pipeline-stages-data"><%- JSON.stringify(pipelineStageMap) %></script>
<script type="application/json" id="lead-selected-stage"><%- JSON.stringify(values.stageId || '') %></script>
