<% if (typeof leadQuotationsCount !== 'undefined' && leadQuotationsCount > 0 && user.can('quotations', 'view')) { %>
    <div class="row mb-3">
        <div class="col-12">
            <div class="card border">
                <div class="card-header d-flex align-items-center justify-content-between py-2">
                    <h6 class="card-title mb-0">
                        <i class="ri-file-text-line me-1"></i> Quotations
                        <span class="badge bg-primary-subtle text-primary ms-1"><%= leadQuotationsCount %></span>
                    </h6>
                    <a href="/company/accounts/quotations?leadId=<%= lead.id %>" class="btn btn-soft-primary btn-sm">View all</a>
                </div>
                <div class="card-body py-2">
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless align-middle mb-0">
                            <thead class="text-muted fs-12">
                                <tr>
                                    <th>Number</th>
                                    <th>Date</th>
                                    <th>Project</th>
                                    <th class="text-end">Total</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% leadQuotations.forEach(function(quotation) { %>
                                    <tr>
                                        <td>
                                            <a href="/company/accounts/quotations/<%= quotation.id %>"><%= quotation.quotationNumber %></a>
                                        </td>
                                        <td><%= quotation.issueDate %></td>
                                        <td><%= quotation.project ? quotation.project.name : '—' %></td>
                                        <td class="text-end"><%= formatIndianCurrency(quotation.totalAmount) %></td>
                                        <td>
                                            <span class="badge <%= getQuotationStatusBadgeClass(quotation.status) %>"><%= formatQuotationStatus(quotation.status) %></span>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% if (leadQuotationsCount > leadQuotations.length) { %>
                        <p class="text-muted fs-12 mb-0 mt-2">Showing latest <%= leadQuotations.length %> of <%= leadQuotationsCount %>.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
<% } %>
