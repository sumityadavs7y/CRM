<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Leads - CRM',
    activeNav: 'leads'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Leads</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item active">Leads</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Lead List</h4>
                                    <% if (user.can('leads', 'edit')) { %>
                                        <div class="flex-shrink-0">
                                            <a href="/company/leads/new" class="btn btn-success btn-sm">
                                                <i class="ri-add-line align-middle me-1"></i> Add Lead
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="card-body">
                                    <% if (leads.length === 0) { %>
                                        <p class="text-muted mb-0">No leads yet.</p>
                                    <% } else { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Customer</th>
                                                        <th>Email</th>
                                                        <th>Subject</th>
                                                        <th>Assignee</th>
                                                        <th>Phone</th>
                                                        <th>Follow-up</th>
                                                        <th>Pipeline</th>
                                                        <th>Stage</th>
                                                        <th>Sources</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% leads.forEach(function(lead) { %>
                                                        <tr>
                                                            <td class="fw-medium"><%= lead.customerName %></td>
                                                            <td><%= lead.email %></td>
                                                            <td><%= lead.subject %></td>
                                                            <td><%= lead.assignee ? lead.assignee.adminName : '—' %></td>
                                                            <td><%= lead.phone || '—' %></td>
                                                            <td><%= lead.followUpDate || '—' %></td>
                                                            <td><%= lead.pipeline ? lead.pipeline.name : '—' %></td>
                                                            <td><%= lead.stage ? lead.stage.name : '—' %></td>
                                                            <td>
                                                                <% if (lead.sources && lead.sources.length) { %>
                                                                    <% lead.sources.forEach(function(source, index) { %>
                                                                        <span class="badge bg-secondary-subtle text-secondary"><%= source.name %></span><% if (index < lead.sources.length - 1) { %> <% } %>
                                                                    <% }); %>
                                                                <% } else { %>
                                                                    —
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <a href="/company/leads/<%= lead.id %>" class="btn btn-soft-primary btn-sm">View</a>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
