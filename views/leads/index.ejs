<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Leads - CRM',
    activeNav: 'leads'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Leads</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item active">Leads</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Lead List</h4>
                                    <% if (user.can('leads', 'edit')) { %>
                                        <div class="flex-shrink-0">
                                            <a href="/company/leads/new" class="btn btn-success btn-sm">
                                                <i class="ri-add-line align-middle me-1"></i> Add Lead
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="card-body">
                                    <% if (leads.length === 0) { %>
                                        <p class="text-muted mb-0">No leads yet.</p>
                                    <% } else { %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0 table-sortable" data-leads-table>
                                                <thead class="table-light">
                                                    <tr>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Customer<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Email<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Subject<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Assignee<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Phone<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="date" scope="col" tabindex="0" aria-sort="none">Follow-up<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="number" scope="col" tabindex="0" aria-sort="none">Score<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Quality<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Pipeline<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th data-sortable data-sort-type="text" scope="col" tabindex="0" aria-sort="none">Stage<i class="sort-indicator ri-arrow-up-down-line" aria-hidden="true"></i></th>
                                                        <th scope="col">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% leads.forEach(function(lead) { %>
                                                        <tr>
                                                            <td class="fw-medium" data-sort-value="<%= lead.customerName %>"><%= lead.customerName %></td>
                                                            <td data-sort-value="<%= lead.email %>"><%= lead.email %></td>
                                                            <td data-sort-value="<%= lead.subject %>"><%= lead.subject %></td>
                                                            <td data-sort-value="<%= lead.assignee ? lead.assignee.adminName : '' %>"><%= lead.assignee ? lead.assignee.adminName : '—' %></td>
                                                            <td data-sort-value="<%= lead.phone || '' %>"><%= lead.phone || '—' %></td>
                                                            <td data-sort-value="<%= lead.followUpDate || '' %>"><%= lead.followUpDate || '—' %></td>
                                                            <td data-sort-value="<%= lead.score ?? '' %>"><%= lead.score ?? '—' %></td>
                                                            <td data-sort-value="<%= lead.quality || '' %>">
                                                                <% if (lead.quality) { %>
                                                                    <span class="badge <%= getLeadQualityBadgeClass(lead.quality) %>"><%= formatLeadQuality(lead.quality) %></span>
                                                                <% } else { %>
                                                                    —
                                                                <% } %>
                                                            </td>
                                                            <td data-sort-value="<%= lead.pipeline ? lead.pipeline.name : '' %>"><%= lead.pipeline ? lead.pipeline.name : '—' %></td>
                                                            <td data-sort-value="<%= lead.stage ? lead.stage.name : '' %>"><%= lead.stage ? lead.stage.name : '—' %></td>
                                                            <td>
                                                                <a href="/company/leads/<%= lead.id %>" class="btn btn-soft-primary btn-sm">View</a>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<script src="/js/leads-list.js"></script>

<%- include('../partials/velzon/app-layout-close') %>
