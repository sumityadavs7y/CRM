<div class="entity-list-filters" data-list-filters>
    <div class="collapse<%= hasActiveFilters ? ' show' : '' %>" id="leadsListFiltersPanel" data-list-filters-panel>
        <form method="get" action="/company/leads" class="entity-list-filters__form">
            <input type="hidden" name="sort" value="<%= pagination.sort %>">
            <input type="hidden" name="dir" value="<%= pagination.dir %>">
            <input type="hidden" name="pageSize" value="<%= pagination.pageSize %>">

            <div class="row g-2 align-items-end">
                <div class="col-md-4 col-lg-3">
                    <label for="leadsFilterQ" class="form-label mb-1">Search</label>
                    <input type="search" class="form-control form-control-sm" id="leadsFilterQ" name="q" value="<%= filters.q || '' %>" placeholder="Customer, email, subject…">
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterAssigneeId" class="form-label mb-1">Assignee</label>
                    <select class="form-select form-select-sm" id="leadsFilterAssigneeId" name="assigneeId">
                        <option value="">All assignees</option>
                        <% filterOptions.assignees.forEach(function(member) { %>
                            <option value="<%= member.id %>"<%= filters.assigneeId === member.id ? ' selected' : '' %>><%= member.adminName %></option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterPipelineId" class="form-label mb-1">Pipeline</label>
                    <select class="form-select form-select-sm" id="leadsFilterPipelineId" name="pipelineId">
                        <option value="">All pipelines</option>
                        <% filterOptions.pipelines.forEach(function(pipeline) { %>
                            <option value="<%= pipeline.id %>"<%= filters.pipelineId === pipeline.id ? ' selected' : '' %>><%= pipeline.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterStageId" class="form-label mb-1">Stage</label>
                    <select class="form-select form-select-sm" id="leadsFilterStageId" name="stageId">
                        <option value="">All stages</option>
                    </select>
                </div>

                <div class="col-md-4 col-lg-1">
                    <label for="leadsFilterQuality" class="form-label mb-1">Quality</label>
                    <select class="form-select form-select-sm" id="leadsFilterQuality" name="quality">
                        <option value="">All</option>
                        <% filterOptions.qualityOptions.forEach(function(option) { %>
                            <option value="<%= option.value %>"<%= filters.quality === option.value ? ' selected' : '' %>><%= option.label %></option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-4 col-lg-1">
                    <label for="leadsFilterScoreMin" class="form-label mb-1">Score min</label>
                    <input type="number" class="form-control form-control-sm" id="leadsFilterScoreMin" name="scoreMin" min="1" max="10" step="1" value="<%= filters.scoreMin !== null ? filters.scoreMin : '' %>" placeholder="1">
                </div>

                <div class="col-md-4 col-lg-1">
                    <label for="leadsFilterScoreMax" class="form-label mb-1">Score max</label>
                    <input type="number" class="form-control form-control-sm" id="leadsFilterScoreMax" name="scoreMax" min="1" max="10" step="1" value="<%= filters.scoreMax !== null ? filters.scoreMax : '' %>" placeholder="10">
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterFollowUpFrom" class="form-label mb-1">Follow-up from</label>
                    <input type="date" class="form-control form-control-sm" id="leadsFilterFollowUpFrom" name="followUpFrom" value="<%= filters.followUpFrom || '' %>">
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterFollowUpTo" class="form-label mb-1">Follow-up to</label>
                    <input type="date" class="form-control form-control-sm" id="leadsFilterFollowUpTo" name="followUpTo" value="<%= filters.followUpTo || '' %>">
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterCreatedFrom" class="form-label mb-1">Created from</label>
                    <input type="date" class="form-control form-control-sm" id="leadsFilterCreatedFrom" name="createdFrom" value="<%= filters.createdFrom || '' %>">
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterCreatedTo" class="form-label mb-1">Created to</label>
                    <input type="date" class="form-control form-control-sm" id="leadsFilterCreatedTo" name="createdTo" value="<%= filters.createdTo || '' %>">
                </div>

                <div class="col-md-4 col-lg-2">
                    <label for="leadsFilterSourceId" class="form-label mb-1">Source</label>
                    <select class="form-select form-select-sm" id="leadsFilterSourceId" name="sourceId">
                        <option value="">All sources</option>
                        <% filterOptions.sources.forEach(function(source) { %>
                            <option value="<%= source.id %>"<%= filters.sourceId === source.id ? ' selected' : '' %>><%= source.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div class="col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm">Apply</button>
                    <% if (hasActiveFilters) { %>
                        <a href="<%= buildListUrl({ page: 1, q: null, assigneeId: null, pipelineId: null, stageId: null, quality: null, scoreMin: null, scoreMax: null, followUpFrom: null, followUpTo: null, createdFrom: null, createdTo: null, sourceId: null }) %>" class="btn btn-light btn-sm">Clear</a>
                    <% } %>
                </div>
            </div>
        </form>
    </div>
</div>

<script type="application/json" id="leads-filter-pipeline-stages-data"><%- JSON.stringify(filterOptions.pipelineStageMap) %></script>
<script type="application/json" id="leads-filter-selected-stage"><%- JSON.stringify(filters.stageId ? String(filters.stageId) : '') %></script>
<script type="application/json" id="entity-list-has-active-filters"><%- JSON.stringify(hasActiveFilters) %></script>
