<%- include('../partials/velzon/app-layout-open', {
    pageTitle: quotation.quotationNumber + ' - Quotation',
    activeNav: 'accounts-quotations'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0"><%= quotation.quotationNumber %></h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item"><a href="/company/accounts/quotations">Quotations</a></li>
                                        <li class="breadcrumb-item active"><%= quotation.quotationNumber %></li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
                    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

                    <div class="row mb-3">
                        <div class="col-12 d-flex flex-wrap gap-2">
                            <a href="/company/accounts/quotations" class="btn btn-light btn-sm">Back to list</a>
                            <% if (canEdit && isEditable) { %>
                                <a href="/company/accounts/quotations/<%= quotation.id %>/edit" class="btn btn-primary btn-sm">Edit</a>
                            <% } %>
                            <% if (canDelete) { %>
                                <form action="/company/accounts/quotations/<%= quotation.id %>/delete" method="post" class="d-inline" onsubmit='return confirm(<%- JSON.stringify(deleteConfirmMessage) %>);'>
                                    <button type="submit" class="btn btn-soft-danger btn-sm">Delete</button>
                                </form>
                            <% } %>
                            <% if (canEdit && quotation.status === 'draft') { %>
                                <form action="/company/accounts/quotations/<%= quotation.id %>/status" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="sent">
                                    <button type="submit" class="btn btn-info btn-sm">Mark as sent</button>
                                </form>
                            <% } %>
                            <% if (canEdit && quotation.status === 'sent') { %>
                                <form action="/company/accounts/quotations/<%= quotation.id %>/status" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="accepted">
                                    <button type="submit" class="btn btn-success btn-sm">Accept</button>
                                </form>
                                <form action="/company/accounts/quotations/<%= quotation.id %>/status" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="rejected">
                                    <button type="submit" class="btn btn-warning btn-sm">Reject</button>
                                </form>
                                <form action="/company/accounts/quotations/<%= quotation.id %>/status" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="cancelled">
                                    <button type="submit" class="btn btn-soft-dark btn-sm">Cancel</button>
                                </form>
                            <% } %>
                            <% if (canEdit && quotation.status === 'draft') { %>
                                <form action="/company/accounts/quotations/<%= quotation.id %>/status" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="cancelled">
                                    <button type="submit" class="btn btn-soft-dark btn-sm">Cancel quotation</button>
                                </form>
                            <% } %>
                            <% if (canEditInvoices && quotation.status === 'accepted' && !quotation.convertedInvoiceId) { %>
                                <form action="/company/accounts/quotations/<%= quotation.id %>/convert" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-success btn-sm">Convert to invoice</button>
                                </form>
                            <% } %>
                            <% if (quotation.convertedInvoiceId) { %>
                                <a href="/company/accounts/invoices/<%= quotation.convertedInvoiceId %>" class="btn btn-soft-success btn-sm">View invoice</a>
                            <% } %>
                            <% if (canViewProjects && quotation.projectId && hasLinkedInventory) { %>
                                <a href="<%= buildProjectInventoryUrl(quotation.projectId) %>" class="btn btn-soft-info btn-sm">
                                    <i class="ri-building-4-line"></i> View inventory
                                </a>
                            <% } %>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-8">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between">
                                    <h5 class="card-title mb-0">Quotation details</h5>
                                    <span class="badge <%= getQuotationStatusBadgeClass(quotation.status) %>"><%= formatQuotationStatus(quotation.status) %></span>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6"><strong>Customer:</strong> <%= quotation.customerName %></div>
                                        <div class="col-md-6"><strong>Email:</strong> <%= quotation.customerEmail %></div>
                                        <div class="col-md-6"><strong>Phone:</strong> <%= quotation.customerPhone || '—' %></div>
                                        <div class="col-md-6"><strong>Assignee:</strong> <%= quotation.assignee ? quotation.assignee.adminName : '—' %></div>
                                        <div class="col-md-6"><strong>Issue date:</strong> <%= quotation.issueDate %></div>
                                        <div class="col-md-6"><strong>Valid until:</strong> <%= quotation.validUntil || '—' %></div>
                                        <div class="col-md-6"><strong>Project:</strong>
                                            <% if (quotation.project && canViewProjects && hasLinkedInventory) { %>
                                                <a href="<%= buildProjectInventoryUrl(quotation.project.id) %>"><%= quotation.project.name %></a>
                                            <% } else if (quotation.project && canViewProjects) { %>
                                                <a href="/company/projects/<%= quotation.project.id %>"><%= quotation.project.name %></a>
                                            <% } else if (quotation.project) { %>
                                                <%= quotation.project.name %>
                                            <% } else { %>—<% } %>
                                        </div>
                                        <div class="col-md-6"><strong>Lead:</strong>
                                            <% if (quotation.lead) { %>
                                                <a href="/company/leads/<%= quotation.lead.id %>"><%= quotation.lead.customerName %></a>
                                            <% } else { %>—<% } %>
                                        </div>
                                        <% if (quotation.customerAddress) { %>
                                            <div class="col-12"><strong>Address:</strong> <%= quotation.customerAddress %></div>
                                        <% } %>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-bordered mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Description</th>
                                                    <th class="text-end">Qty</th>
                                                    <th class="text-end">Rate</th>
                                                    <th class="text-end">Discount</th>
                                                    <th class="text-end">Tax</th>
                                                    <th class="text-end">Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% (quotation.lineItems || []).forEach(function(line, index) { %>
                                                    <tr>
                                                        <td><%= index + 1 %></td>
                                                        <td>
                                                            <%= line.description %>
                                                            <% if (line.unitSnapshot && line.unitSnapshot.blockName) { %>
                                                                <div class="text-muted fs-12"><%= line.unitSnapshot.blockName %> · <%= line.unitSnapshot.unitNumber || '' %></div>
                                                            <% } %>
                                                            <% var linkedUnitId = getLineProjectUnitId(line); %>
                                                            <% if (canViewProjects && quotation.projectId && linkedUnitId) { %>
                                                                <div class="mt-1">
                                                                    <a href="<%= buildProjectInventoryUrl(quotation.projectId, linkedUnitId) %>" class="fs-12">View in inventory</a>
                                                                </div>
                                                            <% } %>
                                                        </td>
                                                        <td class="text-end"><%= line.quantity %></td>
                                                        <td class="text-end"><%= formatIndianCurrency(line.unitPrice) %></td>
                                                        <td class="text-end"><%= formatIndianCurrency(line.discountAmount) %></td>
                                                        <td class="text-end"><%= formatIndianCurrency(line.taxAmount) %></td>
                                                        <td class="text-end"><%= formatIndianCurrency(line.lineTotal) %></td>
                                                    </tr>
                                                <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><strong><%= formatIndianCurrency(quotation.subtotal) %></strong></div>
                                    <div class="d-flex justify-content-between mb-2"><span>Tax</span><strong><%= formatIndianCurrency(quotation.taxAmount) %></strong></div>
                                    <div class="d-flex justify-content-between mb-2"><span>Discount</span><strong><%= formatIndianCurrency(quotation.discountAmount) %></strong></div>
                                    <hr>
                                    <div class="d-flex justify-content-between fs-5"><span>Total</span><strong><%= formatIndianCurrency(quotation.totalAmount) %></strong></div>
                                </div>
                            </div>
                            <% if (quotation.termsAndConditions) { %>
                                <div class="card">
                                    <div class="card-header"><h6 class="mb-0">Terms & conditions</h6></div>
                                    <div class="card-body"><%= quotation.termsAndConditions %></div>
                                </div>
                            <% } %>
                            <% if (quotation.notes) { %>
                                <div class="card">
                                    <div class="card-header"><h6 class="mb-0">Internal notes</h6></div>
                                    <div class="card-body"><%= quotation.notes %></div>
                                </div>
                            <% } %>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
