<div class="row g-3 mb-4">
    <div class="col-md-6">
        <label for="leadId" class="form-label">Lead (optional)</label>
        <select class="form-select" id="leadId" name="leadId">
            <option value="">— Manual customer —</option>
            <% formOptions.leads.forEach(function(lead) { %>
                <option value="<%= lead.id %>" <%= values.leadId == lead.id ? 'selected' : '' %>
                    data-customer-name="<%= lead.customerName %>"
                    data-customer-email="<%= lead.email %>"
                    data-customer-phone="<%= lead.phone || '' %>"
                    data-assignee-id="<%= lead.assigneeId || '' %>">
                    <%= lead.customerName %> (<%= lead.email %>)
                </option>
            <% }); %>
        </select>
    </div>
    <div class="col-md-6">
        <label for="assigneeId" class="form-label">Assignee</label>
        <select class="form-select" id="assigneeId" name="assigneeId">
            <option value="">— None —</option>
            <% formOptions.assignees.forEach(function(assignee) { %>
                <option value="<%= assignee.id %>" <%= values.assigneeId == assignee.id ? 'selected' : '' %>><%= assignee.adminName %></option>
            <% }); %>
        </select>
    </div>
    <div class="col-md-4">
        <label for="customerName" class="form-label">Customer name <span class="text-danger">*</span></label>
        <input type="text" class="form-control" id="customerName" name="customerName" value="<%= values.customerName || '' %>" required>
    </div>
    <div class="col-md-4">
        <label for="customerEmail" class="form-label">Customer email <span class="text-danger">*</span></label>
        <input type="email" class="form-control" id="customerEmail" name="customerEmail" value="<%= values.customerEmail || '' %>" required>
    </div>
    <div class="col-md-4">
        <label for="customerPhone" class="form-label">Customer phone</label>
        <input type="text" class="form-control" id="customerPhone" name="customerPhone" value="<%= values.customerPhone || '' %>">
    </div>
    <div class="col-12">
        <label for="customerAddress" class="form-label">Customer address</label>
        <textarea class="form-control" id="customerAddress" name="customerAddress" rows="2"><%= values.customerAddress || '' %></textarea>
    </div>
    <div class="col-md-4">
        <label for="projectId" class="form-label">Project</label>
        <select class="form-select" id="projectId" name="projectId">
            <option value="">— None —</option>
            <% formOptions.projects.forEach(function(project) { %>
                <option value="<%= project.id %>" <%= values.projectId == project.id ? 'selected' : '' %>><%= project.name %></option>
            <% }); %>
        </select>
    </div>
    <div class="col-md-4">
        <label for="issueDate" class="form-label">Issue date <span class="text-danger">*</span></label>
        <input type="date" class="form-control" id="issueDate" name="issueDate" value="<%= values.issueDate || '' %>" required>
    </div>
    <div class="col-md-4">
        <label for="validUntil" class="form-label">Valid until</label>
        <input type="date" class="form-control" id="validUntil" name="validUntil" value="<%= values.validUntil || '' %>">
    </div>
    <div class="col-12">
        <label for="termsAndConditions" class="form-label">Terms & conditions</label>
        <textarea class="form-control" id="termsAndConditions" name="termsAndConditions" rows="3"><%= values.termsAndConditions || '' %></textarea>
    </div>
    <div class="col-12">
        <label for="notes" class="form-label">Internal notes</label>
        <textarea class="form-control" id="notes" name="notes" rows="2"><%= values.notes || '' %></textarea>
    </div>
    <div class="col-12">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="holdUnitsOnAccept" name="holdUnitsOnAccept" <%= values.holdUnitsOnAccept ? 'checked' : '' %>>
            <label class="form-check-label" for="holdUnitsOnAccept">Hold linked inventory units when quotation is accepted</label>
        </div>
    </div>
</div>

<%- include('_line-items', { values: values }) %>

<div class="row g-3 mt-2">
    <div class="col-md-4 ms-auto">
        <label for="discountAmount" class="form-label">Header discount (₹)</label>
        <input type="number" step="0.01" min="0" class="form-control" id="discountAmount" name="discountAmount" value="<%= values.discountAmount || '0' %>">
    </div>
    <div class="col-md-8">
        <div class="border rounded p-3 bg-light-subtle mt-4">
            <div class="d-flex justify-content-between mb-1"><span>Subtotal</span><strong id="quoteSubtotal">₹0.00</strong></div>
            <div class="d-flex justify-content-between mb-1"><span>Tax</span><strong id="quoteTax">₹0.00</strong></div>
            <div class="d-flex justify-content-between mb-1"><span>Header discount</span><strong id="quoteHeaderDiscount">₹0.00</strong></div>
            <div class="d-flex justify-content-between fs-5 mt-2"><span>Total</span><strong id="quoteTotal">₹0.00</strong></div>
        </div>
    </div>
</div>
