<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="mb-0">Line items</h5>
    <button type="button" class="btn btn-soft-primary btn-sm" id="addLineItemBtn">
        <i class="ri-add-line"></i> Add line
    </button>
</div>

<div class="table-responsive">
    <table class="table table-bordered align-middle mb-0" id="lineItemsTable">
        <thead class="table-light">
            <tr>
                <th style="min-width: 200px;">Unit</th>
                <th style="min-width: 220px;">Description <span class="text-danger">*</span></th>
                <th style="width: 90px;">Qty</th>
                <th style="width: 120px;">Rate (₹) <span class="text-danger">*</span></th>
                <th style="width: 110px;">Discount</th>
                <th style="width: 90px;">Tax %</th>
                <th style="width: 120px;">Line total</th>
                <th style="width: 50px;"></th>
            </tr>
        </thead>
        <tbody id="lineItemsBody">
            <% const lineItems = values.lineItems && values.lineItems.length ? values.lineItems : [{ description: '', projectUnitId: '', quantity: '1', unitPrice: '', discountAmount: '0', taxRate: '' }]; %>
            <% lineItems.forEach(function(line, index) { %>
                <tr class="line-item-row" data-index="<%= index %>">
                    <td>
                        <select class="form-select form-select-sm line-unit-select" name="lineItems[<%= index %>][projectUnitId]">
                            <option value="">— Manual —</option>
                        </select>
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm line-description" name="lineItems[<%= index %>][description]" value="<%= line.description || '' %>" required>
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" class="form-control form-control-sm line-qty" name="lineItems[<%= index %>][quantity]" value="<%= line.quantity || '1' %>">
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" class="form-control form-control-sm line-rate" name="lineItems[<%= index %>][unitPrice]" value="<%= line.unitPrice || '' %>" required>
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" class="form-control form-control-sm line-discount" name="lineItems[<%= index %>][discountAmount]" value="<%= line.discountAmount || '0' %>">
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" class="form-control form-control-sm line-tax-rate" name="lineItems[<%= index %>][taxRate]" value="<%= line.taxRate || '' %>">
                    </td>
                    <td class="line-total-display text-end fw-medium">₹0.00</td>
                    <td>
                        <button type="button" class="btn btn-soft-danger btn-sm remove-line-btn" title="Remove line">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<script type="application/json" id="initialLineItemsData"><%- JSON.stringify(lineItems) %></script>
