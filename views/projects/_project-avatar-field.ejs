<div class="mb-4 project-avatar-field">
    <label class="form-label d-block">Project image</label>
    <div class="project-avatar-field__layout">
        <div
            class="project-avatar-field__preview"
            id="projectAvatarPreview"
            data-initials="<%= avatarInitials %>"
            data-accent="<%= avatarAccent %>"
            data-has-image="<%= hasAvatarPreview ? 'true' : 'false' %>"
            data-preview-url="<%= avatarPreviewUrl || '' %>"
            style="--project-avatar-accent: <%= avatarAccent %>"
        >
            <% if (hasAvatarPreview && avatarPreviewUrl) { %>
                <img src="<%= avatarPreviewUrl %>" alt="" class="project-avatar-field__image" id="projectAvatarPreviewImage">
            <% } else { %>
                <span class="project-avatar-field__initials" id="projectAvatarPreviewInitials"><%= avatarInitials %></span>
            <% } %>
        </div>
        <div class="project-avatar-field__actions">
            <input type="hidden" name="avatarMediaFileId" id="avatarMediaFileId" value="<%= values.avatarMediaFileId || '' %>">
            <% if (canPickMedia) { %>
                <button type="button" class="btn btn-soft-success btn-sm" id="projectAvatarChooseBtn">
                    <i class="ri-image-add-line me-1"></i> Choose image
                </button>
                <button type="button" class="btn btn-soft-secondary btn-sm<%= values.avatarMediaFileId ? '' : ' d-none' %>" id="projectAvatarRemoveBtn">
                    <i class="ri-close-line me-1"></i> Remove
                </button>
                <% if (!canUploadMedia) { %>
                    <p class="text-muted small mb-0 mt-2">You can select an existing image from the Media Library.</p>
                <% } %>
            <% } else { %>
                <p class="text-muted small mb-0">Media Library is not available. An existing project image will still display when set.</p>
            <% } %>
        </div>
    </div>
</div>
