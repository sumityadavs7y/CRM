<div class="modal fade" id="reraModal" tabindex="-1" aria-labelledby="reraModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="reraForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="reraModalLabel">Add RERA Registration</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger d-none" id="reraFormError"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="registrationNumber" class="form-label">Registration number <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="registrationNumber" name="registrationNumber" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="reraState" class="form-label">RERA state <span class="text-danger">*</span></label>
                            <select class="form-select" id="reraState" name="state" required>
                                <option value="">Select state</option>
                                <% reraStates.forEach(function(state) { %>
                                    <option value="<%= state %>"><%= state %></option>
                                <% }); %>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="promoterName" class="form-label">Promoter name</label>
                            <input type="text" class="form-control" id="promoterName" name="promoterName">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="projectNameOnRera" class="form-label">Project name on RERA</label>
                            <input type="text" class="form-control" id="projectNameOnRera" name="projectNameOnRera">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="validFrom" class="form-label">Valid from</label>
                            <input type="date" class="form-control" id="validFrom" name="validFrom">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="validUntil" class="form-label">Valid until</label>
                            <input type="date" class="form-control" id="validUntil" name="validUntil">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="reraStatus" class="form-label">Status</label>
                            <select class="form-select" id="reraStatus" name="status">
                                <% reraStatuses.forEach(function(status) { %>
                                    <option value="<%= status %>"><%= formatReraStatus(status) %></option>
                                <% }); %>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="reraPortalUrl" class="form-label">RERA portal URL</label>
                        <input type="url" class="form-control" id="reraPortalUrl" name="reraPortalUrl" placeholder="https://">
                    </div>
                    <div class="mb-3">
                        <label for="reraNotes" class="form-label">Notes</label>
                        <textarea class="form-control" id="reraNotes" name="notes" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Registration</button>
                </div>
            </form>
        </div>
    </div>
</div>
