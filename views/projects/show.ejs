<%- include('../partials/velzon/app-layout-open', {
    pageTitle: project.name + ' - Project - CRM',
    activeNav: 'projects'
}) %>

<link href="/css/custom.css" rel="stylesheet">

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0"><%= project.name %></h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item"><a href="/company/projects">Projects</a></li>
                                        <li class="breadcrumb-item active">View</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-danger" role="alert"><%= error %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row mb-3">
                        <div class="col-12 d-flex gap-2">
                            <a href="/company/projects" class="btn btn-light btn-sm">Back to Projects</a>
                            <% if (canEdit) { %>
                                <form action="/company/projects/<%= project.id %>/delete" method="post" class="d-inline" onsubmit="return confirm('Delete this project and all inventory? This cannot be undone.');">
                                    <button type="submit" class="btn btn-soft-danger btn-sm">Delete</button>
                                </form>
                            <% } %>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <%- include('./_project-tabs') %>
                        </div>
                    </div>

                    <% if (canEdit) { %>
                        <%- include('./_phase-modal') %>
                        <%- include('./_block-modal') %>
                        <%- include('./_floor-modal') %>
                        <%- include('./_unit-modal') %>
                        <%- include('./_unit-delete-modal') %>
                        <%- include('./_rera-modal') %>
                    <% } %>

<%- include('../partials/velzon/app-layout-close') %>
<script>
    window.projectDetailConfig = {
        projectId: <%= project.id %>,
        activeTab: '<%= activeTab %>',
        focusUnitId: <%- JSON.stringify(typeof focusUnitId !== 'undefined' && focusUnitId ? String(focusUnitId) : null) %>,
        inventoryFocusNodeKeys: <%- JSON.stringify(typeof inventoryFocusNodeKeys !== 'undefined' ? inventoryFocusNodeKeys : []) %>,
        canEdit: <%= canEdit ? 'true' : 'false' %>,
        unitStatusLabels: <%- JSON.stringify(unitStatusLabels) %>,
        unitStatusBadgeClasses: <%- JSON.stringify(unitStatusBadgeClasses) %>
    };
</script>
<script src="/js/project-detail.js"></script>
<script src="/js/project-inventory.js"></script>
<script src="/js/project-rera.js"></script>
