<%- include('../partials/velzon/app-layout-open', {
    pageTitle: project.name + ' - Project - CRM',
    activeNav: 'projects'
}) %>

<link href="/css/custom.css" rel="stylesheet">

                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-danger" role="alert"><%= error %></div>
                            </div>
                        </div>
                    <% } %>

                    <%- include('./_project-hero') %>
                    <%- include('./_project-tab-content') %>

                    <% if (canEdit) { %>
                        <%- include('./_phase-modal') %>
                        <%- include('./_block-modal') %>
                        <%- include('./_floor-modal') %>
                        <%- include('./_unit-modal') %>
                        <%- include('./_unit-delete-modal') %>
                        <%- include('./_rera-modal') %>
                    <% } %>
                    <% if (typeof canViewBudget !== 'undefined' && canViewBudget && canEditBudget) { %>
                        <%- include('./_budget-item-modal') %>
                        <%- include('./_budget-expense-modal') %>
                    <% } %>

<%- include('../partials/velzon/app-layout-close') %>
<script>
    window.projectDetailConfig = {
        projectId: <%= project.id %>,
        activeTab: '<%= activeTab %>',
        focusUnitId: <%- JSON.stringify(typeof focusUnitId !== 'undefined' && focusUnitId ? String(focusUnitId) : null) %>,
        inventoryFocusNodeKeys: <%- JSON.stringify(typeof inventoryFocusNodeKeys !== 'undefined' ? inventoryFocusNodeKeys : []) %>,
        inventoryPhaseTab: <%- JSON.stringify(typeof inventoryPhaseTab !== 'undefined' ? inventoryPhaseTab : null) %>,
        canEdit: <%= canEdit ? 'true' : 'false' %>,
        canViewBudget: <%= (typeof canViewBudget !== 'undefined' && canViewBudget) ? 'true' : 'false' %>,
        canEditBudget: <%= (typeof canEditBudget !== 'undefined' && canEditBudget) ? 'true' : 'false' %>,
        unitStatusLabels: <%- JSON.stringify(unitStatusLabels) %>,
        unitStatusBadgeClasses: <%- JSON.stringify(unitStatusBadgeClasses) %>
    };
</script>
<script src="/js/project-detail.js"></script>
<script src="/js/project-inventory.js"></script>
<script src="/js/project-rera.js"></script>
<% if (typeof canViewBudget !== 'undefined' && canViewBudget) { %>
<script src="/js/project-budget.js"></script>
<% } %>
