<%
    const phases = project.phases || [];
    const allBlocks = project.blocks || [];
    const directBlocks = allBlocks.filter(function(b) { return !b.phaseId; });

    function countUnitsInBlock(block) {
        let total = 0;
        (block.floors || []).forEach(function(floor) {
            total += (floor.units || []).length;
        });
        return total;
    }

    function countUnitsInPhase(phase) {
        let total = 0;
        (phase.blocks || []).forEach(function(block) {
            total += countUnitsInBlock(block);
        });
        return total;
    }

    let inventoryNodeCount = phases.length + allBlocks.length;
    allBlocks.forEach(function(block) {
        inventoryNodeCount += (block.floors || []).length;
    });
    const inventoryCompact = inventoryNodeCount <= 8;
%>

<div class="inventory-toolbar d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <p class="text-muted mb-0 fs-13">Phases → Blocks → Floors → Units</p>
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <% if (phases.length || directBlocks.length) { %>
            <div class="btn-group btn-group-sm" role="group" aria-label="Expand or collapse inventory">
                <button type="button" class="btn btn-soft-secondary" data-inventory-action="expand-all">Expand all</button>
                <button type="button" class="btn btn-soft-secondary" data-inventory-action="collapse-all">Collapse all</button>
            </div>
        <% } %>
        <% if (canEdit) { %>
            <button type="button" class="btn btn-sm btn-outline-primary" data-inventory-action="add-phase">
                <i class="ri-add-line align-middle"></i> Phase
            </button>
            <button type="button" class="btn btn-sm btn-outline-primary" data-inventory-action="add-block" data-phase-id="">
                <i class="ri-add-line align-middle"></i> Block
            </button>
        <% } %>
    </div>
</div>

<% if (!phases.length && !directBlocks.length) { %>
    <div class="inventory-empty text-center py-4">
        <p class="text-muted mb-2">No inventory yet.</p>
        <% if (canEdit) { %>
            <p class="text-muted fs-13 mb-0">Start with a <strong>Block</strong> (single tower) or a <strong>Phase</strong> (for large townships).</p>
        <% } %>
    </div>
<% } else { %>
    <div class="inventory-tree" id="projectInventoryTree" data-inventory-compact="<%= inventoryCompact ? 'true' : 'false' %>">
        <% phases.forEach(function(phase) {
            const phaseTargetId = 'inventory-phase-' + phase.id;
            const phaseFocusExpanded = typeof inventoryFocusNodeKeys !== 'undefined'
                && inventoryFocusNodeKeys.indexOf('phase-' + phase.id) !== -1;
            const phaseExpanded = phaseFocusExpanded || true;
        %>
            <section class="inventory-node inventory-node--phase">
                <div class="inventory-node__header inventory-node__header--expanded">
                    <%- include('./_inventory-collapse-toggle', { targetId: phaseTargetId, expanded: phaseExpanded, label: phase.name }) %>
                    <div
                        class="inventory-node__title inventory-node__title--toggle"
                        role="button"
                        tabindex="0"
                        data-bs-toggle="collapse"
                        data-bs-target="#<%= phaseTargetId %>"
                        aria-expanded="<%= phaseExpanded ? 'true' : 'false' %>"
                        aria-controls="<%= phaseTargetId %>"
                    >
                        <i class="ri-stack-line inventory-node__icon"></i>
                        <span class="fw-medium"><%= phase.name %></span>
                        <span class="badge bg-light text-body ms-1"><%= formatPhaseStatus(phase.status) %></span>
                        <span class="inventory-node__meta"><%= (phase.blocks || []).length %> blocks · <%= countUnitsInPhase(phase) %> units</span>
                    </div>
                    <% if (canEdit) { %>
                        <div class="inventory-node__actions">
                            <button type="button" class="btn btn-sm btn-link inventory-add-btn" data-inventory-action="add-block" data-phase-id="<%= phase.id %>">+ Block</button>
                            <%- include('./_inventory-kebab', {
                                items: [
                                    {
                                        label: 'Edit phase',
                                        action: 'edit-phase',
                                        attrs: {
                                            'data-phase': JSON.stringify({ id: phase.id, name: phase.name, status: phase.status, launchDate: phase.launchDate, possessionDate: phase.possessionDate }),
                                        },
                                    },
                                    {
                                        label: 'Delete phase',
                                        action: 'delete-phase',
                                        danger: true,
                                        attrs: { 'data-phase-id': String(phase.id) },
                                    },
                                ],
                            }) %>
                        </div>
                    <% } %>
                </div>
                <div
                    class="collapse<%= phaseExpanded ? ' show' : '' %> inventory-node__collapse"
                    id="<%= phaseTargetId %>"
                    data-inventory-collapse
                    data-inventory-node-key="phase-<%= phase.id %>"
                    data-inventory-default-expanded="true"
                >
                    <div class="inventory-node__body">
                        <% if (!(phase.blocks || []).length) { %>
                            <p class="text-muted fs-13 mb-0 ps-4">No blocks in this phase.</p>
                        <% } else { %>
                            <% (phase.blocks || []).forEach(function(block) { %>
                                <%- include('./_inventory-block', {
                                    block: block,
                                    inventoryCompact: inventoryCompact,
                                    inventoryFocusNodeKeys: typeof inventoryFocusNodeKeys !== 'undefined' ? inventoryFocusNodeKeys : [],
                                    inventoryFocusUnitId: typeof focusUnitId !== 'undefined' ? focusUnitId : null,
                                }) %>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </section>
        <% }); %>

        <% if (directBlocks.length) { %>
            <section class="inventory-node inventory-node--direct">
                <% if (phases.length) { %>
                    <div class="inventory-node__header inventory-node__header--label">
                        <span class="text-muted fs-13 fw-medium text-uppercase">Blocks without phase</span>
                    </div>
                <% } %>
                <div class="inventory-node__body">
                    <% directBlocks.forEach(function(block) { %>
                        <%- include('./_inventory-block', {
                            block: block,
                            inventoryCompact: inventoryCompact,
                            inventoryFocusNodeKeys: typeof inventoryFocusNodeKeys !== 'undefined' ? inventoryFocusNodeKeys : [],
                            inventoryFocusUnitId: typeof focusUnitId !== 'undefined' ? focusUnitId : null,
                        }) %>
                    <% }); %>
                </div>
            </section>
        <% } %>
    </div>
<% } %>
