<%
    const phases = project.phases || [];
    const allBlocks = project.blocks || [];
    const directBlocks = allBlocks.filter(function(b) { return !b.phaseId; });
    const hasPhases = phases.length > 0;

    function countUnitsInBlock(block) {
        let total = 0;
        (block.floors || []).forEach(function(floor) {
            total += (floor.units || []).length;
        });
        return total;
    }

    function countUnitsInPhase(phase) {
        let total = 0;
        (phase.blocks || []).forEach(function(block) {
            total += countUnitsInBlock(block);
        });
        return total;
    }

    let inventoryNodeCount = phases.length + allBlocks.length;
    allBlocks.forEach(function(block) {
        inventoryNodeCount += (block.floors || []).length;
    });
    const inventoryCompact = inventoryNodeCount <= 8;

    const focusKeys = typeof inventoryFocusNodeKeys !== 'undefined' ? inventoryFocusNodeKeys : [];
    const focusUnit = typeof focusUnitId !== 'undefined' ? focusUnitId : null;

    let activePhaseTab = typeof inventoryPhaseTab !== 'undefined' && inventoryPhaseTab ? inventoryPhaseTab : null;
    if (!activePhaseTab) {
        if (hasPhases) {
            activePhaseTab = 'phase-' + phases[0].id;
        } else {
            activePhaseTab = 'default';
        }
    }
%>

<div class="card">
    <div class="card-header align-items-center d-flex">
        <h5 class="card-title mb-0 flex-grow-1">Inventory</h5>
        <div class="flex-shrink-0 d-flex flex-wrap gap-2 align-items-center">
        <% if (phases.length || directBlocks.length) { %>
            <div class="btn-group btn-group-sm" role="group" aria-label="Expand or collapse inventory">
                <button type="button" class="btn btn-soft-secondary" data-inventory-action="expand-all">Expand all</button>
                <button type="button" class="btn btn-soft-secondary" data-inventory-action="collapse-all">Collapse all</button>
            </div>
        <% } %>
        <% if (canEdit) { %>
            <button type="button" class="btn btn-sm btn-outline-primary" data-inventory-action="add-phase">
                <i class="ri-add-line align-middle"></i> Phase
            </button>
            <button type="button" class="btn btn-sm btn-outline-primary" data-inventory-action="add-block">
                <i class="ri-add-line align-middle"></i> Block
            </button>
        <% } %>
        </div>
    </div>
    <div class="card-body">
        <p class="text-muted fs-13 mb-3">Blocks → Floors → Units</p>

<% if (!phases.length && !directBlocks.length) { %>
    <div class="inventory-empty text-center py-4">
        <p class="text-muted mb-2">No inventory yet.</p>
        <% if (canEdit) { %>
            <p class="text-muted fs-13 mb-0">Start with a <strong>Block</strong> (single tower) or a <strong>Phase</strong> (for large townships).</p>
        <% } %>
    </div>
<% } else if (hasPhases) { %>
    <ul class="nav nav-tabs nav-tabs-custom inventory-phase-tabs mb-3" id="inventoryPhaseTabs" role="tablist">
        <% phases.forEach(function(phase) {
            const phaseTabKey = 'phase-' + phase.id;
            const isActive = activePhaseTab === phaseTabKey;
        %>
            <li class="nav-item" role="presentation">
                <button
                    class="nav-link<%= isActive ? ' active' : '' %>"
                    id="inventory-phase-tab-<%= phase.id %>"
                    data-bs-toggle="tab"
                    data-bs-target="#inventory-phase-pane-<%= phase.id %>"
                    type="button"
                    role="tab"
                    aria-controls="inventory-phase-pane-<%= phase.id %>"
                    aria-selected="<%= isActive ? 'true' : 'false' %>"
                    data-inventory-phase-tab="<%= phaseTabKey %>"
                >
                    <%= phase.name %>
                </button>
            </li>
        <% }); %>
        <li class="nav-item" role="presentation">
            <button
                class="nav-link<%= activePhaseTab === 'default' ? ' active' : '' %>"
                id="inventory-phase-tab-default"
                data-bs-toggle="tab"
                data-bs-target="#inventory-phase-pane-default"
                type="button"
                role="tab"
                aria-controls="inventory-phase-pane-default"
                aria-selected="<%= activePhaseTab === 'default' ? 'true' : 'false' %>"
                data-inventory-phase-tab="default"
            >
                Default
            </button>
        </li>
    </ul>

    <div class="tab-content" id="inventoryPhaseTabContent">
        <% phases.forEach(function(phase) {
            const phaseTabKey = 'phase-' + phase.id;
            const isActive = activePhaseTab === phaseTabKey;
        %>
            <div
                class="tab-pane fade<%= isActive ? ' show active' : '' %>"
                id="inventory-phase-pane-<%= phase.id %>"
                role="tabpanel"
                aria-labelledby="inventory-phase-tab-<%= phase.id %>"
                data-inventory-phase-pane="<%= phaseTabKey %>"
            >
                <div class="inventory-phase-pane__header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="badge bg-light text-body"><%= formatPhaseStatus(phase.status) %></span>
                        <span class="text-muted fs-13"><%= (phase.blocks || []).length %> blocks · <%= countUnitsInPhase(phase) %> units</span>
                    </div>
                    <% if ((typeof canViewBudget !== 'undefined' && canViewBudget) || canEdit) { %>
                        <div class="d-flex align-items-center gap-1">
                            <% if (typeof canViewBudget !== 'undefined' && canViewBudget) { %>
                                <a href="/company/projects/<%= project.id %>?tab=budget&amp;phaseTab=<%= phaseTabKey %>" class="btn btn-sm btn-soft-primary">
                                    <i class="ri-money-rupee-circle-line align-middle"></i> Budget
                                </a>
                            <% } %>
                            <% if (canEdit) { %>
                                <button type="button" class="btn btn-sm btn-link inventory-add-btn" data-inventory-action="add-block">+ Block</button>
                                <%- include('./_inventory-kebab', {
                                    items: [
                                        {
                                            label: 'Edit phase',
                                            action: 'edit-phase',
                                            attrs: {
                                                'data-phase': JSON.stringify({ id: phase.id, name: phase.name, status: phase.status, launchDate: phase.launchDate, possessionDate: phase.possessionDate }),
                                            },
                                        },
                                        {
                                            label: 'Delete phase',
                                            action: 'delete-phase',
                                            danger: true,
                                            attrs: { 'data-phase-id': String(phase.id) },
                                        },
                                    ],
                                }) %>
                            <% } %>
                        </div>
                    <% } %>
                </div>
                <%- include('./_inventory-blocks-list', {
                    blocks: phase.blocks || [],
                    inventoryTreeId: 'projectInventoryTree-phase-' + phase.id,
                    inventoryPhasePane: phaseTabKey,
                    inventoryCompact: inventoryCompact,
                    inventoryFocusNodeKeys: focusKeys,
                    focusUnitId: focusUnit,
                    emptyMessage: 'No blocks in this phase.',
                }) %>
            </div>
        <% }); %>

        <div
            class="tab-pane fade<%= activePhaseTab === 'default' ? ' show active' : '' %>"
            id="inventory-phase-pane-default"
            role="tabpanel"
            aria-labelledby="inventory-phase-tab-default"
            data-inventory-phase-pane="default"
        >
            <div class="inventory-phase-pane__header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <span class="text-muted fs-13">Blocks not assigned to a phase</span>
                <div class="d-flex align-items-center gap-1">
                    <% if (typeof canViewBudget !== 'undefined' && canViewBudget) { %>
                        <a href="/company/projects/<%= project.id %>?tab=budget&amp;phaseTab=default" class="btn btn-sm btn-soft-primary">
                            <i class="ri-money-rupee-circle-line align-middle"></i> Budget
                        </a>
                    <% } %>
                    <% if (canEdit) { %>
                        <button type="button" class="btn btn-sm btn-link inventory-add-btn" data-inventory-action="add-block">+ Block</button>
                    <% } %>
                </div>
            </div>
            <%- include('./_inventory-blocks-list', {
                blocks: directBlocks,
                inventoryTreeId: 'projectInventoryTree-default',
                inventoryPhasePane: 'default',
                inventoryCompact: inventoryCompact,
                inventoryFocusNodeKeys: focusKeys,
                focusUnitId: focusUnit,
                emptyMessage: 'No blocks in this section.',
            }) %>
        </div>
    </div>
<% } else { %>
    <%- include('./_inventory-blocks-list', {
        blocks: directBlocks,
        inventoryTreeId: 'projectInventoryTree',
        inventoryPhasePane: 'default',
        inventoryCompact: inventoryCompact,
        inventoryFocusNodeKeys: focusKeys,
        focusUnitId: focusUnit,
        emptyMessage: 'No blocks yet.',
    }) %>
<% } %>
    </div>
</div>
