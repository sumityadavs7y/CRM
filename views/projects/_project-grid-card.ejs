<%
    const cardUrl = '/company/projects/' + project.id;
    const editUrl = '/company/projects/' + project.id + '/edit';
    const location = formatProjectListLocation(project);
    const unitsLabel = formatProjectListUnits(project);
    const showEdit = typeof canEdit !== 'undefined' && canEdit;
%>
<div class="col">
    <article
        class="project-card<%= project.isActive === false ? ' project-card--inactive' : '' %>"
        data-project-card-url="<%= cardUrl %>"
        tabindex="0"
        role="link"
        aria-label="<%= project.name %>"
    >
        <div class="project-card__status-strip project-card__status-strip--<%= project.status %>"></div>
        <div class="project-card__media">
            <% if (showEdit) { %>
                <a
                    href="<%= editUrl %>"
                    class="btn btn-sm btn-light project-card__edit"
                    title="Edit project"
                    aria-label="Edit <%= project.name %>"
                >
                    <i class="ri-pencil-line"></i>
                </a>
            <% } %>
            <% if (project.hasAvatar && project.avatarThumbUrl) { %>
                <img src="<%= project.avatarThumbUrl %>" alt="" class="project-card__image" loading="lazy" decoding="async">
            <% } else { %>
                <div class="project-card__placeholder" style="--project-avatar-accent: <%= project.avatarAccent %>">
                    <span class="project-card__initials"><%= project.avatarInitials %></span>
                </div>
            <% } %>
        </div>
        <div class="project-card__body">
            <h3 class="project-card__title mb-0"><%= project.name %></h3>
            <div class="project-card__meta">
                <span class="badge bg-light text-body"><%= formatProjectType(project.projectType) %></span>
                <% if (project.isActive === false) { %>
                    <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                <% } %>
            </div>
            <% if (location !== '—') { %>
                <p class="project-card__location text-muted mb-0"><i class="ri-map-pin-line me-1"></i><%= location %></p>
            <% } %>
            <div class="project-card__stats">
                <% if (unitsLabel !== '—') { %>
                    <span class="project-card__stat"><i class="ri-building-2-line me-1"></i><%= unitsLabel %></span>
                <% } %>
                <% if (project.reraStatus) { %>
                    <span class="badge <%= getReraStatusBadgeClass(project.reraStatus) %>"><%= formatReraStatus(project.reraStatus) %></span>
                <% } %>
            </div>
            <div class="project-card__status">
                <span class="badge <%= getProjectStatusBadgeClass(project.status) %>"><%= formatProjectStatus(project.status) %></span>
            </div>
        </div>
    </article>
</div>
