<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">RERA registration details for this project.</p>
    <% if (canEdit) { %>
        <button type="button" class="btn btn-success btn-sm" data-rera-action="add">
            <i class="ri-add-line"></i> Add Registration
        </button>
    <% } %>
</div>

<% const registrations = project.reraRegistrations || []; %>
<% if (!registrations.length) { %>
    <p class="text-muted mb-0">No RERA registrations recorded yet.</p>
<% } else { %>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Registration No.</th>
                    <th>State</th>
                    <th>Promoter</th>
                    <th>Valid Until</th>
                    <th>Status</th>
                    <th>Portal</th>
                    <% if (canEdit) { %><th>Actions</th><% } %>
                </tr>
            </thead>
            <tbody>
                <% registrations.forEach(function(reg) { %>
                    <tr>
                        <td class="fw-medium"><%= reg.registrationNumber %></td>
                        <td><%= reg.state %></td>
                        <td><%= reg.promoterName || '—' %></td>
                        <td><%= reg.validUntil || '—' %></td>
                        <td><span class="badge <%= getReraStatusBadgeClass(reg.status) %>"><%= formatReraStatus(reg.status) %></span></td>
                        <td>
                            <% if (reg.reraPortalUrl) { %>
                                <a href="<%= reg.reraPortalUrl %>" target="_blank" rel="noopener noreferrer">View</a>
                            <% } else { %>
                                —
                            <% } %>
                        </td>
                        <% if (canEdit) { %>
                            <td>
                                <button type="button" class="btn btn-soft-secondary btn-sm" data-rera-action="edit" data-rera='<%- JSON.stringify(reg) %>'>Edit</button>
                                <button type="button" class="btn btn-soft-danger btn-sm" data-rera-action="delete" data-rera-id="<%= reg.id %>">Delete</button>
                            </td>
                        <% } %>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } %>
