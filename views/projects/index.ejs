<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Project Management - CRM',
    activeNav: 'projects'
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Project Management</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item active">Projects</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (success) { %>
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-success" role="alert"><%= success %></div>
                            </div>
                        </div>
                    <% } %>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Project List</h4>
                                    <div class="flex-shrink-0 d-flex gap-2 align-items-center">
                                        <%- include('../partials/list/filters-toggle', { filtersPanelId: 'projectsListFiltersPanel', hasActiveFilters }) %>
                                        <% if (user.can('project_management', 'edit')) { %>
                                            <a href="/company/projects/new" class="btn btn-success btn-sm">
                                                <i class="ri-add-line align-middle me-1"></i> Add Project
                                            </a>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <%- include('./_list-filters') %>

                                    <% if (pagination.total === 0) { %>
                                        <% if (hasActiveFilters) { %>
                                            <p class="text-muted mb-0">No projects match your filters.</p>
                                        <% } else { %>
                                            <p class="text-muted mb-0">No projects yet.</p>
                                        <% } %>
                                    <% } else { %>
                                        <%- include('../partials/pagination-bar', { position: 'top' }) %>
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0 table-sortable">
                                                <thead class="table-light">
                                                    <tr>
                                                        <% listColumns.forEach(function(column) {
                                                            const isSortable = listSortColumns.has(column.key);
                                                            const isActive = pagination.sort === column.key;
                                                            const nextDir = isActive && pagination.dir === 'asc' ? 'desc' : 'asc';
                                                            const sortHref = buildListUrl({ page: 1, sort: column.key, dir: nextDir });
                                                            const ariaSort = isActive ? (pagination.dir === 'asc' ? 'ascending' : 'descending') : 'none';
                                                            const sortIcon = isActive
                                                                ? (pagination.dir === 'asc' ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line')
                                                                : 'ri-arrow-up-down-line';
                                                        %>
                                                            <th scope="col" data-list-column="<%= column.key %>" aria-sort="<%= isSortable ? ariaSort : 'none' %>">
                                                                <% if (isSortable) { %>
                                                                    <a href="<%= sortHref %>" class="text-body text-decoration-none d-inline-flex align-items-center">
                                                                        <%= column.label %>
                                                                        <i class="sort-indicator <%= sortIcon %>" aria-hidden="true"></i>
                                                                    </a>
                                                                <% } else { %>
                                                                    <%= column.label %>
                                                                <% } %>
                                                            </th>
                                                        <% }); %>
                                                        <th scope="col">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% projects.forEach(function(project) { %>
                                                        <tr>
                                                            <% listColumns.forEach(function(column) { %>
                                                                <%- include('./_list-cell', { project, column }) %>
                                                            <% }); %>
                                                            <td>
                                                                <a href="/company/projects/<%= project.id %>" class="btn btn-soft-primary btn-sm">View</a>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                        <%- include('../partials/pagination-bar', { position: 'bottom' }) %>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<script type="application/json" id="entity-list-config"><%- JSON.stringify({
    filtersPanelId: 'projectsListFiltersPanel',
    filtersExpandedStorageKey: listFiltersExpandedStorageKey,
    columnsStorageKey: listColumnsStorageKey
}) %></script>
<script src="/js/entity-list.js"></script>

<%- include('../partials/velzon/app-layout-close') %>
