<div class="modal fade" id="unitDeleteModal" tabindex="-1" aria-labelledby="unitDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="unitDeleteModalLabel">Delete unit</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">
                    Unit <strong id="unitDeleteModalUnitNumber"></strong> is linked to accounts records:
                </p>
                <ul class="list-unstyled mb-3 fs-14">
                    <li><span id="unitDeleteModalQuotationCount">0</span> quotation(s)</li>
                    <li><span id="unitDeleteModalInvoiceCount">0</span> invoice(s)</li>
                    <li><span id="unitDeleteModalReceiptCount">0</span> receipt(s)</li>
                </ul>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="unitDeleteModalDeleteRelated">
                    <label class="form-check-label" for="unitDeleteModalDeleteRelated">
                        Delete all related quotations, invoices, and receipts
                    </label>
                </div>
                <p class="text-muted fs-13 mt-2 mb-0" id="unitDeleteModalUnlinkNote">
                    If unchecked, records are kept and only unlinked from this unit.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="unitDeleteModalConfirm">Delete unit</button>
            </div>
        </div>
    </div>
</div>
