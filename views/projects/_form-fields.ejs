<div class="mb-3">
    <label for="name" class="form-label">Project name <span class="text-danger">*</span></label>
    <input type="text" class="form-control" id="name" name="name" value="<%= values.name || '' %>" required>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label for="projectType" class="form-label">Project type</label>
        <select class="form-select" id="projectType" name="projectType">
            <% projectTypes.forEach(function(type) { %>
                <option value="<%= type %>"<%= String(values.projectType || '') === type ? 'selected' : '' %>><%= formatProjectType(type) %></option>
            <% }); %>
        </select>
    </div>
    <div class="col-md-6 mb-3">
        <label for="projectStatus" class="form-label">Status</label>
        <select class="form-select" id="projectStatus" name="status">
            <% projectStatuses.forEach(function(status) { %>
                <option value="<%= status %>"<%= String(values.status || '') === status ? 'selected' : '' %>><%= formatProjectStatus(status) %></option>
            <% }); %>
        </select>
    </div>
</div>

<div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea class="form-control" id="description" name="description" rows="3"><%= values.description || '' %></textarea>
</div>

<div class="mb-3">
    <label for="addressLine1" class="form-label">Address line 1</label>
    <input type="text" class="form-control" id="addressLine1" name="addressLine1" value="<%= values.addressLine1 || '' %>">
</div>

<div class="mb-3">
    <label for="addressLine2" class="form-label">Address line 2</label>
    <input type="text" class="form-control" id="addressLine2" name="addressLine2" value="<%= values.addressLine2 || '' %>">
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <label for="city" class="form-label">City</label>
        <input type="text" class="form-control" id="city" name="city" value="<%= values.city || '' %>">
    </div>
    <div class="col-md-4 mb-3">
        <label for="state" class="form-label">State</label>
        <input type="text" class="form-control" id="state" name="state" value="<%= values.state || '' %>">
    </div>
    <div class="col-md-4 mb-3">
        <label for="pincode" class="form-label">Pincode</label>
        <input type="text" class="form-control" id="pincode" name="pincode" value="<%= values.pincode || '' %>">
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <label for="totalLandAreaSqft" class="form-label">Total land area (sq ft)</label>
        <input type="number" class="form-control" id="totalLandAreaSqft" name="totalLandAreaSqft" step="0.01" min="0" value="<%= values.totalLandAreaSqft !== '' && values.totalLandAreaSqft != null ? values.totalLandAreaSqft : '' %>">
    </div>
    <div class="col-md-4 mb-3">
        <label for="launchDate" class="form-label">Launch date</label>
        <input type="date" class="form-control" id="launchDate" name="launchDate" value="<%= values.launchDate || '' %>">
    </div>
    <div class="col-md-4 mb-3">
        <label for="possessionDate" class="form-label">Possession date</label>
        <input type="date" class="form-control" id="possessionDate" name="possessionDate" value="<%= values.possessionDate || '' %>">
    </div>
</div>

<div class="mb-3">
    <label for="isActive" class="form-label">Active</label>
    <select class="form-select" id="isActive" name="isActive">
        <option value="true"<%= values.isActive === 'true' || values.isActive === true ? ' selected' : '' %>>Yes</option>
        <option value="false"<%= values.isActive === 'false' || values.isActive === false ? ' selected' : '' %>>No</option>
    </select>
</div>
