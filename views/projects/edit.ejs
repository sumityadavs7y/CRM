<%- include('../partials/velzon/app-layout-open', {
    pageTitle: 'Edit ' + project.name + ' - CRM',
    activeNav: 'projects'
}) %>

<link href="/css/custom.css" rel="stylesheet">

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0">Edit Project</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item"><a href="/company/projects">Projects</a></li>
                                        <li class="breadcrumb-item"><a href="/company/projects/<%= project.id %>"><%= project.name %></a></li>
                                        <li class="breadcrumb-item active">Edit</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form action="/company/projects/<%= project.id %>" method="post">
                        <div class="row">
                            <div class="col-lg-8">
                                <% if (error) { %>
                                    <div class="alert alert-danger" role="alert"><%= error %></div>
                                <% } %>

                                <div class="card">
                                    <div class="card-body">
                                        <%- include('./_form-fields-profile') %>
                                    </div>
                                </div>

                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">Location</h5>
                                    </div>
                                    <div class="card-body">
                                        <%- include('./_form-fields-location') %>
                                    </div>
                                </div>

                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">Schedule & financials</h5>
                                    </div>
                                    <div class="card-body">
                                        <%- include('./_form-fields-schedule') %>
                                    </div>
                                </div>

                                <div class="text-end mb-4">
                                    <a href="/company/projects/<%= project.id %>" class="btn btn-light w-sm">Cancel</a>
                                    <button class="btn btn-success w-sm" type="submit">Save Changes</button>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">Current project</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-flex align-items-center gap-3 mb-3">
                                            <%- include('./_project-avatar', { project, size: 'md' }) %>
                                            <div>
                                                <h6 class="mb-1"><%= project.name %></h6>
                                                <span class="badge <%= getProjectStatusBadgeClass(project.status) %>"><%= formatProjectStatus(project.status) %></span>
                                            </div>
                                        </div>
                                        <p class="text-muted fs-13 mb-0">Changes here update the project profile. Inventory, RERA, and budget are managed from the project detail page.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

<script type="application/json" id="projectFormConfig"><%- JSON.stringify({
    canUploadMedia: typeof canUploadMedia !== 'undefined' ? canUploadMedia : false
}) %></script>

<%- include('../partials/velzon/app-layout-close') %>
<script src="/js/project-form.js"></script>
