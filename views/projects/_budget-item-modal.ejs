<div class="modal fade" id="budgetItemModal" tabindex="-1" aria-labelledby="budgetItemModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="budgetItemForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="budgetItemModalLabel">Add Budget Item</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger d-none" id="budgetItemFormError"></div>
                    <input type="hidden" id="budgetItemBudgetId" name="budgetId">
                    <input type="hidden" id="budgetItemParentId" name="parentId">
                    <div class="mb-3">
                        <label for="budgetItemName" class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="budgetItemName" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="budgetItemExpectedAmount" class="form-label">Expected amount (₹)</label>
                        <input type="number" class="form-control" id="budgetItemExpectedAmount" name="expectedAmount" step="0.01" min="0">
                        <div class="form-text">Leave blank to sum from sub-items.</div>
                    </div>
                    <div class="mb-3">
                        <label for="budgetItemDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="budgetItemDescription" name="description" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Item</button>
                </div>
            </form>
        </div>
    </div>
</div>
