<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Permission Denied - CRM</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/style/Admin/dist/default/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4 text-center">
                        <h4 class="mb-3">Permission denied</h4>
                        <p class="text-muted mb-3">
                            Your role does not grant <strong><%= action %></strong> access to this section<% if (companyName) { %> for <strong><%= companyName %></strong><% } %>.
                        </p>
                        <a href="/dashboard" class="btn btn-primary btn-sm">Back to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
