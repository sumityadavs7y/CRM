<%- include('../partials/velzon/app-layout-open', {
    pageTitle: module.label + ' - Accounts',
    activeNav: activeNav
}) %>

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0"><%= module.label %></h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/dashboard">CRM</a></li>
                                        <li class="breadcrumb-item">Accounts & Transactions</li>
                                        <li class="breadcrumb-item active"><%= module.label %></li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <% if (module.key === 'transactions') { %>
                                        <%- include('_transactions-placeholder', { transactionViews: transactionViews }) %>
                                    <% } else { %>
                                        <%- include('_placeholder', {
                                            icon: module.icon,
                                            title: module.label,
                                            description: module.placeholderDescription
                                        }) %>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

<%- include('../partials/velzon/app-layout-close') %>
